---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Streich Force Enterprises — Real-World Expertise. Smarter Systems. Reliable Execution.">
  <Nav />

  <!-- SITE STATUS BANNER -->
  <div class="site-banner">
    <div class="site-banner-inner">
      <span class="site-banner-dot"></span>
      <span class="site-banner-text">Site in progress &mdash; Full launch coming soon. Questions? <a href="mailto:info&#x40;streichforce.com">info&#x40;streichforce.com</a></span>
    </div>
  </div>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>
    <div class="hero-grid"></div>
    <div class="hero-glow"></div>
    <div class="hero-content">
      <p class="hero-eyebrow">Streich Force Enterprises &mdash; streichforce.com</p>
      <div class="hero-wm">
        <img src="/logo-dark.png" alt="Streich Force Enterprises" class="hero-logo" />
      </div>
      <div class="hero-tagline">
        <p class="hero-tag-main">Real-World Expertise. Smarter Systems. Reliable Execution.</p>
        <p class="hero-tag-sub">We support businesses through:</p>
        <ul class="hero-list">
          <li>Specialized commercial service &amp; repair</li>
          <li>Back-office operations &amp; automation</li>
          <li>Equipment &amp; container sourcing</li>
        </ul>
        <p class="hero-tag-cta">Choose what you need below and get exactly the right solution.</p>
      </div>
    </div>
    <div class="hero-scroll"><span>Scroll</span></div>
  </section>

  <!-- DIVISION STRIP -->
  <div class="div-strip">
    <a href="/services" class="div-strip-tab ent">
      <div class="dst-dot"></div>
      <span class="dst-label">01 &mdash; Services</span>
    </a>
    <a href="/solutions" class="div-strip-tab sol">
      <div class="dst-dot"></div>
      <span class="dst-label">02 &mdash; Solutions</span>
    </a>
    <a href="/containers" class="div-strip-tab con">
      <div class="dst-dot"></div>
      <span class="dst-label">03 &mdash; Containers</span>
    </a>
  </div>

  <!-- DIVISIONS -->
  <section class="divisions" id="divisions">
    <div class="div-section-head">
      <p class="div-section-eye">Our Divisions</p>
      <h2 class="div-section-title">Choose the Path to<br />Solving Your Problem</h2>
    </div>
    <div class="div-cards">

      <div class="div-card ent" onclick="window.location='/services'">
        <div class="dc-bar"></div>
        <div class="dc-num">01</div>
        <div class="dc-body">
          <p class="dc-tag">Division 01 &mdash; Commercial Service &amp; Repair</p>
          <h3 class="dc-title">Commercial Service &amp; Repair</h3>
          <p class="dc-desc">High-level diagnostics and precision repair when others can't solve the problem.</p>
          <ul class="dc-checks">
            <li>&#10004; 40+ years experience</li>
            <li>&#10004; Trusted by national brands</li>
            <li>&#10004; Complex issues handled right the first time</li>
          </ul>
          <div class="dc-actions">
            <a href="/contact/enterprise" class="dc-cta ent-cta" onclick="event.stopPropagation()">Request Expert Service</a>
            <a href="/services" class="dc-mi ent-mi" onclick="event.stopPropagation()">More Info</a>
          </div>
        </div>
        <div class="dc-arrow">&#8594;</div>
      </div>

      <div class="div-card sol" onclick="window.location='/solutions'">
        <div class="dc-bar"></div>
        <div class="dc-num">02</div>
        <div class="dc-body">
          <p class="dc-tag">Division 02 &mdash; Back-Office Support &amp; Systems</p>
          <h3 class="dc-title">Streich Force Solutions</h3>
          <p class="dc-desc">Eliminate manual work, clean up your data, and streamline operations.</p>
          <ul class="dc-checks">
            <li>&#10004; Billing, reporting, and workflow support</li>
            <li>&#10004; Data cleanup and standardization</li>
            <li>&#10004; Built to scale with smarter systems</li>
          </ul>
          <div class="dc-actions">
            <a href="/contact/solutions" class="dc-cta sol-cta" onclick="event.stopPropagation()">Fix My Back Office</a>
            <a href="/solutions" class="dc-mi sol-mi" onclick="event.stopPropagation()">More Info</a>
          </div>
        </div>
        <div class="dc-arrow">&#8594;</div>
      </div>

      <div class="div-card con" onclick="window.location='/containers'">
        <div class="dc-bar"></div>
        <div class="dc-num">03</div>
        <div class="dc-body">
          <p class="dc-tag">Division 03 &mdash; Container Sales &amp; Sourcing</p>
          <h3 class="dc-title">Streich Force Containers</h3>
          <p class="dc-desc">Access to available containers with straightforward pricing.</p>
          <ul class="dc-checks">
            <li>&#10004; View available inventory</li>
            <li>&#10004; Request quotes quickly</li>
            <li>&#10004; Source exactly what you need</li>
          </ul>
          <div class="dc-actions">
            <a href="/contact/containers" class="dc-cta con-cta" onclick="event.stopPropagation()">Browse Containers</a>
            <a href="/containers" class="dc-mi con-mi" onclick="event.stopPropagation()">More Info</a>
          </div>
        </div>
        <div class="dc-arrow">&#8594;</div>
      </div>

    </div>
  </section>

  <!-- ABOUT -->
  <section class="about" id="about">
    <div>
      <p class="div-section-eye">About Streich Force</p>
      <h2 class="div-section-title" style="margin-bottom:2rem;">Three Focus Areas.<br />One Standard: Get It Done Right.</h2>
      <div class="about-text">
        <p>We operate across three specialized areas:</p>
        <ul class="about-list">
          <li><strong>Commercial Service &amp; Repair</strong> — High-level diagnostics and precision work when others can't solve the problem</li>
          <li><strong>Back-Office Support &amp; Systems</strong> — Streamlining operations, cleaning data, and eliminating manual work</li>
          <li><strong>Container Sales &amp; Sourcing</strong> — Direct, efficient access to available inventory and pricing</li>
        </ul>
        <p>Each one solves a different problem — but they're all built on the same principle: real experience, practical execution, and no wasted motion.</p>
      </div>
    </div>
    <div class="about-stats">
      <div class="stat">
        <div class="stat-val">Real-World<br />Experience</div>
        <div class="stat-lbl">Years of hands-on work in the industries we serve — no theory, no consulting.</div>
      </div>
      <div class="stat">
        <div class="stat-val">No<br />Overhead</div>
        <div class="stat-lbl">You work directly with the people doing the job. No layers. No middlemen.</div>
      </div>
      <div class="stat">
        <div class="stat-val">Direct<br />Execution</div>
        <div class="stat-lbl">Work is handled by experienced operators — not passed off or outsourced.</div>
      </div>
      <div class="stat">
        <div class="stat-val">Built for<br />Results</div>
        <div class="stat-lbl">We measure success by what gets solved, delivered, and working — nothing else.</div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <div class="cta-band" id="contact">
    <div>
      <h3 class="cta-title">Got Something Specific in Mind?</h3>
      <p class="cta-sub">Tell us what you need, and we'll help you find the right solution.</p>
    </div>
    <a href="mailto:info&#x40;streichforce.com" class="sf-btn-primary">Get In Touch</a>
  </div>

  <Footer />
</BaseLayout>

<style>
/* ── HERO ── */
.hero {
  height: 100vh; min-height: 620px;
  display: flex; align-items: flex-end;
  padding: 0 var(--sf-pad) 4.5rem;
  position: relative; overflow: hidden;
}
.hero-bg {
  position: absolute; inset: 0; z-index: 0;
  background-image: url('/hero-bg.png');
  background-size: cover; background-position: center right;
  opacity: 0.28; filter: grayscale(20%) sepia(10%);
}
.hero-overlay {
  position: absolute; inset: 0; z-index: 1;
  background:
    linear-gradient(to top, rgba(17,17,17,1) 0%, rgba(17,17,17,0.75) 30%, rgba(17,17,17,0.2) 60%, rgba(17,17,17,0.4) 100%),
    linear-gradient(to right, rgba(17,17,17,0.5) 0%, transparent 55%);
}
.hero-grid {
  position: absolute; inset: 0; z-index: 2;
  background-image:
    linear-gradient(rgba(255,255,255,0.022) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.022) 1px, transparent 1px);
  background-size: 56px 56px;
  animation: gridDrift 24s linear infinite;
}
@keyframes gridDrift { from{transform:translateY(0)} to{transform:translateY(56px)} }
.hero-glow {
  position: absolute; top: -20%; right: -10%; z-index: 2;
  width: 50%; height: 80%;
  background: radial-gradient(ellipse at top right, rgba(192,57,43,0.06), transparent 65%);
  pointer-events: none;
}
.hero-content { position: relative; z-index: 3; max-width: 800px; }
.hero-eyebrow {
  font-family: var(--sf-font-display); font-weight: 600; font-size: 0.78rem;
  letter-spacing: 0.38em; text-transform: uppercase; color: var(--sf-rust);
  margin-bottom: 1.25rem;
  opacity: 0; animation: sf-rise-up 0.7s ease forwards 0.2s;
}
.hero-wm {
  opacity: 0; animation: sf-rise-up 0.7s ease forwards 0.4s;
  margin-bottom: 1.75rem;
}
.hero-logo {
  height: clamp(90px, 14vw, 160px);
  width: auto; display: block;
}
.hero-tagline { opacity: 0; animation: sf-rise-up 0.7s ease forwards 0.7s; }
.hero-tag-main {
  font-family: var(--sf-font-display); font-weight: 700;
  font-size: clamp(1.1rem, 2vw, 1.4rem);
  color: var(--sf-text-primary); letter-spacing: 0.03em;
  margin-bottom: 0.75rem; line-height: 1.3;
}
.hero-tag-sub {
  font-size: 1rem; font-weight: 300;
  color: var(--sf-text-secondary); margin-bottom: 0.5rem;
}
.hero-list {
  list-style: none; margin: 0 0 1rem 0; padding: 0;
  display: flex; flex-direction: column; gap: 0.4rem;
}
.hero-list li {
  font-size: 1rem; font-weight: 300;
  color: var(--sf-text-secondary); line-height: 1.6;
  padding-left: 1.25rem; position: relative;
}
.hero-list li::before {
  content: '▸'; position: absolute; left: 0;
  color: var(--sf-rust); font-size: 0.8rem; top: 0.15em;
}
.hero-tag-cta {
  font-family: var(--sf-font-display); font-weight: 600;
  font-size: 0.78rem; letter-spacing: 0.05em;
  text-transform: uppercase; color: var(--sf-rust);
}
.hero-scroll {
  position: absolute; bottom: 2rem; right: var(--sf-pad); z-index: 3;
  display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
  opacity: 0; animation: sf-fade-in 1s ease forwards 1.5s;
}
.hero-scroll span {
  font-family: var(--sf-font-display); font-weight: 600; font-size: 0.62rem;
  letter-spacing: 0.3em; text-transform: uppercase; color: var(--sf-text-muted); writing-mode: vertical-rl;
}
.hero-scroll::after {
  content: ''; width: 1px; height: 44px;
  background: linear-gradient(to bottom, var(--sf-rust), transparent);
  animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }

/* ── DIVISION STRIP ── */
.div-strip {
  display: grid; grid-template-columns: repeat(3, 1fr);
  background: var(--sf-surface);
  border-top: 1px solid var(--sf-border); border-bottom: 1px solid var(--sf-border);
}
.div-strip-tab {
  display: flex; align-items: center; gap: 0.75rem;
  padding: 1.1rem var(--sf-pad); border-right: 1px solid var(--sf-border);
  transition: background 0.2s; cursor: pointer;
}
.div-strip-tab:last-child { border-right: none; }
.div-strip-tab:hover { background: var(--sf-card-hover); }
.dst-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.div-strip-tab.ent .dst-dot { background: var(--sf-ent); }
.div-strip-tab.sol .dst-dot { background: var(--sf-sol); }
.div-strip-tab.con .dst-dot { background: var(--sf-con); }
.dst-label {
  font-family: var(--sf-font-display); font-weight: 700; font-size: 0.78rem;
  letter-spacing: 0.18em; text-transform: uppercase; color: var(--sf-text-secondary); transition: color 0.2s;
}
.div-strip-tab.ent:hover .dst-label { color: var(--sf-ent-b); }
.div-strip-tab.sol:hover .dst-label { color: var(--sf-sol-b); }
.div-strip-tab.con:hover .dst-label { color: var(--sf-con-b); }

/* ── DIVISION CARDS ── */
.divisions { padding: 5rem var(--sf-pad); }
.div-section-head { margin-bottom: 3rem; }
.div-section-eye {
  font-family: var(--sf-font-display); font-weight: 600; font-size: 0.78rem;
  letter-spacing: 0.4em; text-transform: uppercase; color: var(--sf-rust); margin-bottom: 0.6rem;
}
.div-section-title {
  font-family: var(--sf-font-display); font-weight: 900;
  font-size: clamp(2.2rem, 4vw, 3.2rem);
  text-transform: uppercase; letter-spacing: 0.02em; color: var(--sf-text-primary); line-height: 1;
}
.div-cards { display: flex; flex-direction: column; gap: 3px; }
.div-card {
  display: grid; grid-template-columns: 6px 110px 1fr 60px;
  align-items: center; background: var(--sf-surface);
  transition: background 0.25s; min-height: 200px; cursor: pointer;
}
.div-card:hover { background: var(--sf-card-hover); }
.dc-bar { height: 100%; min-height: 200px; }
.div-card.ent .dc-bar { background: var(--sf-ent); }
.div-card.sol .dc-bar { background: var(--sf-sol); }
.div-card.con .dc-bar { background: var(--sf-con); }
.dc-num {
  font-family: var(--sf-font-display); font-weight: 900; font-size: 5.5rem;
  line-height: 1; text-align: center; user-select: none;
  transition: color 0.3s; padding: 2rem 0 2rem 1.5rem;
}
.div-card.ent .dc-num { color: rgba(192,57,43,0.12); }
.div-card.sol .dc-num { color: rgba(46,109,164,0.12); }
.div-card.con .dc-num { color: rgba(196,122,13,0.12); }
.div-card.ent:hover .dc-num { color: rgba(192,57,43,0.22); }
.div-card.sol:hover .dc-num { color: rgba(46,109,164,0.22); }
.div-card.con:hover .dc-num { color: rgba(196,122,13,0.22); }
.dc-body { padding: 2.5rem 2rem 2.5rem 1.5rem; }
.dc-tag {
  font-family: var(--sf-font-display); font-weight: 600; font-size: 0.72rem;
  letter-spacing: 0.35em; text-transform: uppercase; margin-bottom: 0.4rem;
}
.div-card.ent .dc-tag { color: var(--sf-ent); }
.div-card.sol .dc-tag { color: var(--sf-sol); }
.div-card.con .dc-tag { color: var(--sf-con); }
.dc-title {
  font-family: var(--sf-font-display); font-weight: 900;
  font-size: clamp(1.5rem, 2.5vw, 2.2rem);
  text-transform: uppercase; letter-spacing: 0.02em;
  color: var(--sf-text-primary); line-height: 1; margin-bottom: 0.6rem;
}
.dc-desc {
  font-size: 1rem; font-weight: 300;
  color: var(--sf-text-secondary); line-height: 1.7;
  max-width: 580px; margin-bottom: 1rem;
}
.dc-checks {
  list-style: none; padding: 0; margin: 0 0 1.5rem 0;
  display: flex; flex-direction: column; gap: 0.3rem;
}
.dc-checks li { font-size: 0.95rem; font-weight: 400; color: var(--sf-text-secondary); line-height: 1.5; }
.div-card.ent .dc-checks li { color: rgba(224,80,64,0.9); }
.div-card.sol .dc-checks li { color: rgba(90,159,212,0.9); }
.div-card.con .dc-checks li { color: rgba(232,160,48,0.9); }
.dc-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: center; }
.dc-cta {
  display: inline-block; font-family: var(--sf-font-display); font-weight: 700;
  font-size: 0.75rem; letter-spacing: 0.18em; text-transform: uppercase;
  padding: 0.65rem 1.4rem; border: 1px solid; transition: all 0.2s;
}
.ent-cta { border-color: var(--sf-ent); color: var(--sf-ent); }
.sol-cta { border-color: var(--sf-sol); color: var(--sf-sol); }
.con-cta { border-color: var(--sf-con); color: var(--sf-con); }
.div-card.ent:hover .ent-cta { background: var(--sf-ent); color: #fff; }
.div-card.sol:hover .sol-cta { background: var(--sf-sol); color: #fff; }
.div-card.con:hover .con-cta { background: var(--sf-con); color: #fff; }
.dc-mi {
  display: inline-block; font-family: var(--sf-font-display); font-weight: 600;
  font-size: 0.75rem; letter-spacing: 0.18em; text-transform: uppercase;
  padding: 0.65rem 1.4rem; border: 1px solid var(--sf-border-md);
  color: var(--sf-text-secondary); transition: all 0.2s;
}
.dc-mi:hover { border-color: var(--sf-text-secondary); color: var(--sf-text-primary); }
.dc-arrow {
  display: flex; align-items: center; justify-content: center;
  font-size: 1.8rem; color: rgba(255,255,255,0.15);
  transition: transform 0.3s, color 0.3s; padding-right: 1.5rem;
}
.div-card.ent:hover .dc-arrow { transform: translateX(6px); color: var(--sf-ent-b); }
.div-card.sol:hover .dc-arrow { transform: translateX(6px); color: var(--sf-sol-b); }
.div-card.con:hover .dc-arrow { transform: translateX(6px); color: var(--sf-con-b); }

/* ── ABOUT ── */
.about {
  padding: 6rem var(--sf-pad); border-top: 1px solid var(--sf-border);
  display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start;
}
.about-text p { font-size: 1.05rem; font-weight: 300; color: var(--sf-text-secondary); line-height: 1.8; margin-bottom: 1.25rem; }
.about-text strong { color: var(--sf-text-primary); font-weight: 500; }
.about-list {
  list-style: none; padding: 0; margin: 0 0 1.5rem 0;
  display: flex; flex-direction: column; gap: 0.75rem;
}
.about-list li {
  font-size: 1rem; font-weight: 300; color: var(--sf-text-secondary);
  line-height: 1.7; padding-left: 1.25rem; position: relative;
}
.about-list li::before {
  content: '▸'; position: absolute; left: 0;
  color: var(--sf-rust); font-size: 0.8rem; top: 0.2em;
}
.about-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 2px; background: var(--sf-border); align-content: start; }
.stat { background: var(--sf-surface); padding: 2rem 1.75rem; }
.stat-val {
  font-family: var(--sf-font-display); font-weight: 900; font-size: 1.6rem;
  color: var(--sf-rust); line-height: 1.1; margin-bottom: 0.75rem;
  text-transform: uppercase; letter-spacing: 0.02em;
}
.stat-lbl { font-size: 0.95rem; font-weight: 300; color: var(--sf-text-secondary); line-height: 1.7; }

/* ── CTA ── */
.cta-band {
  margin: 0 var(--sf-pad) 6rem; padding: 3.5rem 4rem;
  background: var(--sf-surface); border-left: 5px solid var(--sf-rust);
  display: flex; align-items: center; justify-content: space-between;
  gap: 2.5rem; flex-wrap: wrap; position: relative; overflow: hidden;
}
.cta-band::after {
  content: 'SF'; position: absolute; right: 2rem; top: 50%; transform: translateY(-50%);
  font-family: var(--sf-font-display); font-weight: 900; font-size: 9rem;
  color: rgba(255,255,255,0.025); pointer-events: none; user-select: none;
}
.cta-title { font-family: var(--sf-font-display); font-weight: 900; font-size: clamp(1.4rem, 2.5vw, 2rem); text-transform: uppercase; color: var(--sf-text-primary); margin-bottom: 0.4rem; }
.cta-sub { font-size: 1rem; font-weight: 300; color: var(--sf-text-secondary); line-height: 1.6; }

/* ── RESPONSIVE ── */
@media (max-width: 900px) {
  .div-strip { grid-template-columns: 1fr; }
  .div-strip-tab { border-right: none; border-bottom: 1px solid var(--sf-border); }
  .div-card { grid-template-columns: 6px 1fr 40px; }
  .dc-num { display: none; }
  .dc-body { padding: 2rem 1.5rem; }
  .about { grid-template-columns: 1fr; gap: 3rem; }
  .about-stats { grid-template-columns: 1fr 1fr; }
  .cta-band { flex-direction: column; align-items: flex-start; padding: 2.5rem 2rem; }
}
</style>
