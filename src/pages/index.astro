---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Home">
  <Nav />

  <!-- SITE STATUS BANNER -->
  <div class="site-banner">
    <div class="site-banner-inner">
      <span class="site-banner-dot"></span>
      <span class="site-banner-text">Site in progress &mdash; Full launch coming soon. Questions? <a href="mailto:info&#x40;streichforce.com">info&#x40;streichforce.com</a></span>
    </div>
  </div>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-overlay"></div>
    <div class="hero-grid"></div>
    <div class="hero-glow"></div>
    <div class="hero-content">
      <p class="hero-eyebrow">Streich Force Enterprises &mdash; streichforce.com</p>
      <div class="hero-wm" id="heroWm">
        <span class="hero-wm-text" id="heroText">STREICH <span class="f">FORCE</span></span>
        <span class="hero-wm-rule" id="heroRule"></span>
        <span class="hero-wm-ent" id="heroEnt">ENTERPRISES</span>
      </div>
      <p class="hero-sub">
        On-demand industry expertise for your operations.<br />
        <span class="hero-sub-dim">Specialized work. Delivered by years of experience.</span>
      </p>
    </div>
    <div class="hero-scroll"><span>Scroll</span></div>
  </section>

  <!-- DIVISION STRIP -->
  <div class="div-strip">
    <a href="/enterprise" class="div-strip-tab ent">
      <div class="dst-dot"></div>
      <span class="dst-label">01 &mdash; Enterprise</span>
    </a>
    <a href="/solutions" class="div-strip-tab sol">
      <div class="dst-dot"></div>
      <span class="dst-label">02 &mdash; Solutions</span>
    </a>
    <a href="/containers" class="div-strip-tab con">
      <div class="dst-dot"></div>
      <span class="dst-label">03 &mdash; Containers</span>
    </a>
  </div>

  <!-- DIVISIONS -->
  <section class="divisions" id="divisions">
    <div class="div-section-head">
      <p class="div-section-eye">Our Divisions</p>
      <h2 class="div-section-title">Where Do We Fit<br />In Your Business?</h2>
    </div>
    <div class="div-cards">

      <a href="/enterprise" class="div-card ent">
        <div class="dc-bar"></div>
        <div class="dc-num">01</div>
        <div class="dc-body">
          <p class="dc-tag">Division 01 &mdash; Specialized Repair &amp; Fabrication</p>
          <h3 class="dc-title">Streich Force Enterprise</h3>
          <p class="dc-summary">When standard contractors fall short, we step in.</p>
          <p class="dc-desc">Specialized repair, custom fabrication, and site maintenance for pharmacies, retail chains, and commercial properties. Structural, technical, or one-of-a-kind &mdash; we build it, fix it, or improve it.</p>
          <div class="dc-pills">
            <span class="pill">Pharmacies &amp; Retail</span>
            <span class="pill">Specialized Repair</span>
            <span class="pill">Custom Fabrication</span>
          </div>
        </div>
        <div class="dc-arrow">&#8594;</div>
      </a>

      <a href="/solutions" class="div-card sol">
        <div class="dc-bar"></div>
        <div class="dc-num">02</div>
        <div class="dc-body">
          <p class="dc-tag">Division 02 &mdash; Back-Office Operations</p>
          <h3 class="dc-title">Streich Force Solutions</h3>
          <p class="dc-summary">An extension of your back office.</p>
          <p class="dc-desc">We become your dedicated operational team for container wholesalers and similar small businesses &mdash; managing inventory, purchasing, sales orders, invoicing, gate activity, and daily coordination. Powered by Triplemeter for real-time inventory and gate intelligence, plus our own simplified, industry-specific order management system that replaces spreadsheets, email chains, and disconnected tools.</p>
          <div class="dc-pills">
            <span class="pill">Inventory &amp; Gate Management</span>
            <span class="pill">Order &amp; Sales Processing</span>
            <span class="pill">Operations Support</span>
          </div>
        </div>
        <div class="dc-arrow">&#8594;</div>
      </a>

      <a href="/containers" class="div-card con">
        <div class="dc-bar"></div>
        <div class="dc-num">03</div>
        <div class="dc-body">
          <p class="dc-tag">Division 03 &mdash; Shipping Container Sales</p>
          <h3 class="dc-title">Streich Force Containers</h3>
          <p class="dc-summary">Your direct source for shipping containers.</p>
          <p class="dc-desc">New and used 20ft and 40ft units &mdash; standard and high-cube &mdash; for storage, job sites, or bulk wholesale. Straightforward pricing with delivery available.</p>
          <div class="dc-pills">
            <span class="pill">20ft &amp; 40ft</span>
            <span class="pill">New &amp; Used</span>
            <span class="pill">Bulk Pricing</span>
          </div>
        </div>
        <div class="dc-arrow">&#8594;</div>
      </a>

    </div>
  </section>

  <!-- ABOUT -->
  <section class="about" id="about">
    <div>
      <p class="div-section-eye">About Streich Force</p>
      <h2 class="div-section-title" style="margin-bottom:2rem;">Deeply Specialized.<br />Built on Real Experience.</h2>
      <div class="about-text">
        <p><strong>We're not consultants. We're operators.</strong></p>
        <p>Our company is run by people who have spent years doing the actual work &mdash; not just studying it. We understand the container industry, retail site maintenance, and back-office realities because we've lived them day in and day out.</p>
        <p>We serve businesses that want results without overhead. No layers of management, no account reps who don't know your world. You deal directly with the people who actually do the work.</p>
        <p>When container wholesalers need reliable back-office support, or when major retail chains need repairs and fabrication that no one else can figure out &mdash; they call us. That's not by accident.</p>
      </div>
    </div>
    <div class="about-stats">
      <div class="stat">
        <div class="stat-val">Real-World<br />Experience</div>
        <div class="stat-lbl">Years of hands-on work in the industries we serve &mdash; not theory, not consulting.</div>
      </div>
      <div class="stat">
        <div class="stat-val">No<br />Overhead</div>
        <div class="stat-lbl">You deal directly with the people doing the work. No account reps, no layers.</div>
      </div>
      <div class="stat full-width">
        <div class="stat-val">Built for<br />Results</div>
        <div class="stat-lbl">We measure success by what gets solved, delivered, and working &mdash; nothing else.</div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <div class="cta-band" id="contact">
    <div>
      <h3 class="cta-title">Got Something Specific in Mind?</h3>
      <p class="cta-sub">Tell us what you need, and we'll help you find the right solution.</p>
    </div>
    <a href="mailto:info@streichforce.com" class="sf-btn-primary">Get In Touch</a>
  </div>

  <Footer />
</BaseLayout>

<style>
/* HERO */
.hero {
  height: 100vh; min-height: 600px;
  display: flex; align-items: flex-end;
  padding: 0 var(--sf-pad) 4.5rem;
  position: relative; overflow: hidden;
}
.hero-bg {
  position: absolute; inset: 0; z-index: 0;
  background-image: url('/hero-bg.png');
  background-size: cover; background-position: center right;
  opacity: 0.28; filter: grayscale(20%) sepia(10%);
}
.hero-overlay {
  position: absolute; inset: 0; z-index: 1;
  background:
    linear-gradient(to top, rgba(17,17,17,1) 0%, rgba(17,17,17,0.75) 30%, rgba(17,17,17,0.2) 60%, rgba(17,17,17,0.4) 100%),
    linear-gradient(to right, rgba(17,17,17,0.5) 0%, transparent 55%);
}
.hero-grid {
  position: absolute; inset: 0; z-index: 2;
  background-image:
    linear-gradient(rgba(255,255,255,0.022) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.022) 1px, transparent 1px);
  background-size: 56px 56px;
  animation: gridDrift 24s linear infinite;
}
@keyframes gridDrift { from{transform:translateY(0)} to{transform:translateY(56px)} }
.hero-glow {
  position: absolute; top: -20%; right: -10%; z-index: 2;
  width: 50%; height: 80%;
  background: radial-gradient(ellipse at top right, rgba(192,57,43,0.06), transparent 65%);
  pointer-events: none;
}
.hero-content { position: relative; z-index: 3; }

.hero-eyebrow {
  font-family: var(--sf-font-display); font-weight: 600; font-size: 0.7rem;
  letter-spacing: 0.38em; text-transform: uppercase; color: var(--sf-rust);
  margin-bottom: 1.25rem;
  opacity: 0; animation: sf-rise-up 0.7s ease forwards 0.2s;
}
.hero-wm { display: inline-block; }
.hero-wm-text {
  font-family: var(--sf-font-display); font-weight: 900;
  font-size: clamp(3.5rem, 9vw, 9rem);
  line-height: 0.88; letter-spacing: 0.01em; text-transform: uppercase;
  color: var(--sf-text-primary); white-space: nowrap; display: block;
  opacity: 0; animation: sf-rise-up 0.7s ease forwards 0.4s;
}
.hero-wm-text .f { color: var(--sf-rust); }
.hero-wm-rule {
  height: 4px; background: var(--sf-rust);
  margin: 1rem 0 0.65rem; display: block;
  opacity: 0; animation: sf-rise-up 0.7s ease forwards 0.6s;
}
.hero-wm-ent {
  font-family: var(--sf-font-display); font-weight: 700;
  font-size: clamp(0.55rem, 1.1vw, 0.9rem);
  text-transform: uppercase; color: var(--sf-text-muted); display: block;
  opacity: 0; animation: sf-rise-up 0.7s ease forwards 0.7s;
}
.hero-sub {
  font-size: clamp(1rem, 1.5vw, 1.15rem); font-weight: 300;
  color: var(--sf-text-secondary); line-height: 1.75; max-width: 520px; margin-top: 2rem;
  opacity: 0; animation: sf-rise-up 0.7s ease forwards 0.85s;
}
.hero-sub-dim { font-size: 0.9em; color: var(--sf-text-muted); }
.hero-scroll {
  position: absolute; bottom: 2rem; right: var(--sf-pad); z-index: 3;
  display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
  opacity: 0; animation: sf-fade-in 1s ease forwards 1.5s;
}
.hero-scroll span {
  font-family: var(--sf-font-display); font-weight: 600; font-size: 0.62rem;
  letter-spacing: 0.3em; text-transform: uppercase; color: var(--sf-text-muted); writing-mode: vertical-rl;
}
.hero-scroll::after {
  content: ''; width: 1px; height: 44px;
  background: linear-gradient(to bottom, var(--sf-rust), transparent);
  animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }

/* DIVISION STRIP */
.div-strip {
  display: grid; grid-template-columns: repeat(3, 1fr);
  background: var(--sf-surface);
  border-top: 1px solid var(--sf-border); border-bottom: 1px solid var(--sf-border);
}
.div-strip-tab {
  display: flex; align-items: center; gap: 0.75rem;
  padding: 1.1rem var(--sf-pad); border-right: 1px solid var(--sf-border);
  transition: background 0.2s; cursor: pointer;
}
.div-strip-tab:last-child { border-right: none; }
.div-strip-tab:hover { background: var(--sf-card-hover); }
.dst-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.div-strip-tab.ent .dst-dot { background: var(--sf-ent); }
.div-strip-tab.sol .dst-dot { background: var(--sf-sol); }
.div-strip-tab.con .dst-dot { background: var(--sf-con); }
.dst-label {
  font-family: var(--sf-font-display); font-weight: 700; font-size: 0.72rem;
  letter-spacing: 0.18em; text-transform: uppercase; color: var(--sf-text-secondary); transition: color 0.2s;
}
.div-strip-tab.ent:hover .dst-label { color: var(--sf-ent-b); }
.div-strip-tab.sol:hover .dst-label { color: var(--sf-sol-b); }
.div-strip-tab.con:hover .dst-label { color: var(--sf-con-b); }

/* DIVISION CARDS */
.divisions { padding: 5rem var(--sf-pad); }
.div-section-head { margin-bottom: 3rem; }
.div-section-eye {
  font-family: var(--sf-font-display); font-weight: 600; font-size: 0.68rem;
  letter-spacing: 0.4em; text-transform: uppercase; color: var(--sf-rust); margin-bottom: 0.6rem;
}
.div-section-title {
  font-family: var(--sf-font-display); font-weight: 900;
  font-size: clamp(2rem, 4vw, 3rem);
  text-transform: uppercase; letter-spacing: 0.02em; color: var(--sf-text-primary); line-height: 1;
}
.div-cards { display: flex; flex-direction: column; gap: 3px; }
.div-card {
  display: grid; grid-template-columns: 6px 110px 1fr 60px;
  align-items: center; background: var(--sf-surface);
  transition: background 0.25s; min-height: 160px;
}
.div-card:hover { background: var(--sf-card-hover); }
.dc-bar { height: 100%; min-height: 160px; }
.div-card.ent .dc-bar { background: var(--sf-ent); }
.div-card.sol .dc-bar { background: var(--sf-sol); }
.div-card.con .dc-bar { background: var(--sf-con); }
.dc-num {
  font-family: var(--sf-font-display); font-weight: 900; font-size: 5.5rem;
  line-height: 1; text-align: center; user-select: none;
  transition: color 0.3s; padding: 2rem 0 2rem 1.5rem;
}
.div-card.ent .dc-num { color: rgba(192,57,43,0.12); }
.div-card.sol .dc-num { color: rgba(46,109,164,0.12); }
.div-card.con .dc-num { color: rgba(196,122,13,0.12); }
.div-card.ent:hover .dc-num { color: rgba(192,57,43,0.22); }
.div-card.sol:hover .dc-num { color: rgba(46,109,164,0.22); }
.div-card.con:hover .dc-num { color: rgba(196,122,13,0.22); }
.dc-body { padding: 2.5rem 2rem 2.5rem 1.5rem; }
.dc-tag {
  font-family: var(--sf-font-display); font-weight: 600; font-size: 0.65rem;
  letter-spacing: 0.35em; text-transform: uppercase; margin-bottom: 0.4rem;
}
.div-card.ent .dc-tag { color: var(--sf-ent); }
.div-card.sol .dc-tag { color: var(--sf-sol); }
.div-card.con .dc-tag { color: var(--sf-con); }
.dc-title {
  font-family: var(--sf-font-display); font-weight: 900;
  font-size: clamp(1.5rem, 2.5vw, 2.2rem);
  text-transform: uppercase; letter-spacing: 0.02em;
  color: var(--sf-text-primary); line-height: 1; margin-bottom: 0.6rem;
}
.dc-summary { font-size: 1rem; font-weight: 500; color: var(--sf-text-primary); line-height: 1.5; margin-bottom: 0.75rem; }
.dc-desc { font-size: 0.93rem; font-weight: 300; color: var(--sf-text-secondary); line-height: 1.75; max-width: 620px; margin-bottom: 1.25rem; }
.dc-pills { display: flex; flex-wrap: wrap; gap: 6px; }
.pill {
  font-family: var(--sf-font-display); font-weight: 600; font-size: 0.6rem;
  letter-spacing: 0.14em; text-transform: uppercase; padding: 0.28rem 0.8rem; border-radius: 2px;
}
.div-card.ent .pill { background: var(--sf-ent-bg); color: var(--sf-ent-b); border: 1px solid rgba(192,57,43,0.2); }
.div-card.sol .pill { background: var(--sf-sol-bg); color: var(--sf-sol-b); border: 1px solid rgba(46,109,164,0.2); }
.div-card.con .pill { background: var(--sf-con-bg); color: var(--sf-con-b); border: 1px solid rgba(196,122,13,0.2); }
.dc-arrow {
  display: flex; align-items: center; justify-content: center;
  font-size: 1.8rem; color: rgba(255,255,255,0.15);
  transition: transform 0.3s, color 0.3s; padding-right: 1.5rem;
}
.div-card.ent:hover .dc-arrow { transform: translateX(6px); color: var(--sf-ent-b); }
.div-card.sol:hover .dc-arrow { transform: translateX(6px); color: var(--sf-sol-b); }
.div-card.con:hover .dc-arrow { transform: translateX(6px); color: var(--sf-con-b); }

/* ABOUT */
.about {
  padding: 6rem var(--sf-pad); border-top: 1px solid var(--sf-border);
  display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start;
}
.about-text p { font-size: 1rem; font-weight: 300; color: var(--sf-text-secondary); line-height: 1.85; margin-bottom: 1.25rem; }
.about-text strong { color: var(--sf-text-primary); font-weight: 500; }
.about-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 2px; background: var(--sf-border); align-content: start; }
.stat { background: var(--sf-surface); padding: 2rem 1.75rem; }
.stat.full-width { grid-column: 1 / -1; }
.stat-val {
  font-family: var(--sf-font-display); font-weight: 900; font-size: 1.6rem;
  color: var(--sf-rust); line-height: 1.1; margin-bottom: 0.75rem;
  text-transform: uppercase; letter-spacing: 0.02em;
}
.stat-lbl { font-size: 0.875rem; font-weight: 300; color: var(--sf-text-secondary); line-height: 1.65; }

/* CTA */
.cta-band {
  margin: 0 var(--sf-pad) 6rem; padding: 3.5rem 4rem;
  background: var(--sf-surface); border-left: 5px solid var(--sf-rust);
  display: flex; align-items: center; justify-content: space-between;
  gap: 2.5rem; flex-wrap: wrap; position: relative; overflow: hidden;
}
.cta-band::after {
  content: 'SF'; position: absolute; right: 2rem; top: 50%; transform: translateY(-50%);
  font-family: var(--sf-font-display); font-weight: 900; font-size: 9rem;
  color: rgba(255,255,255,0.025); pointer-events: none; user-select: none;
}
.cta-title { font-family: var(--sf-font-display); font-weight: 900; font-size: clamp(1.4rem, 2.5vw, 2rem); text-transform: uppercase; color: var(--sf-text-primary); margin-bottom: 0.4rem; }
.cta-sub { font-size: 0.95rem; font-weight: 300; color: var(--sf-text-secondary); }

/* RESPONSIVE */
@media (max-width: 900px) {
  .div-strip { grid-template-columns: 1fr; }
  .div-strip-tab { border-right: none; border-bottom: 1px solid var(--sf-border); }
  .div-card { grid-template-columns: 6px 1fr 40px; }
  .dc-num { display: none; }
  .dc-body { padding: 2rem 1.5rem; }
  .about { grid-template-columns: 1fr; gap: 3rem; }
  .cta-band { flex-direction: column; align-items: flex-start; padding: 2.5rem 2rem; }
}
</style>

<script>
function fitWm() {
  const txt  = document.getElementById('heroText');
  const rule = document.getElementById('heroRule');
  const ent  = document.getElementById('heroEnt');
  if (!txt || !rule || !ent) return;
  const w = txt.getBoundingClientRect().width;
  if (w < 10) return;
  rule.style.width = w + 'px';
  rule.style.display = 'block';
  ent.style.letterSpacing = '0.05em';
  ent.style.width = 'auto';
  ent.style.display = 'block';
  requestAnimationFrame(() => {
    const nw = ent.getBoundingClientRect().width;
    const spacing = (w - nw) / 11;
    ent.style.letterSpacing = spacing + 'px';
    ent.style.width = w + 'px';
  });
}
document.addEventListener('DOMContentLoaded', fitWm);
window.addEventListener('load', fitWm);
window.addEventListener('resize', fitWm);
if (document.fonts?.ready) document.fonts.ready.then(() => { fitWm(); setTimeout(fitWm, 300); });
setTimeout(fitWm, 600);
setTimeout(fitWm, 1200);
</script>
