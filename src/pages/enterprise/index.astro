---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="Enterprise — Specialized Repair & Fabrication"
  description="When standard contractors fall short, we step in. Specialized repair, custom fabrication, and site maintenance for pharmacies, retail chains, and commercial properties."
>
  <Nav active="enterprise" />

  <!-- HERO -->
  <section class="div-hero">
    <div class="div-hero-bg"></div>
    <div class="div-hero-inner">
      <p class="sf-eyebrow ent-eye">Division 01 &mdash; Specialized Repair &amp; Fabrication</p>
      <h1 class="div-hero-title">When Standard<br /><span class="ent-accent">Contractors Fall Short</span></h1>
      <p class="div-hero-sub">We step in. Specialized commercial repair and custom fabrication for pharmacies, retail chains, and commercial properties — delivered by people who've actually done the work.</p>
      <div class="div-hero-cta">
        <a href="/contact/enterprise" class="btn-primary ent-btn">Request Expert Service</a>
        <a href="#services" class="btn-ghost">See What We Do</a>
      </div>
    </div>
    <div class="hero-accent-bar ent-bar"></div>
  </section>

  <!-- POSITIONING -->
  <section class="div-position">
    <div class="div-inner">
      <div class="div-pos-statement">
        <p class="sf-eyebrow ent-eye">Our Lane</p>
        <h2 class="div-pos-title">We're not in the regular rotation.<br />We're who you call when the rotation fails.</h2>
      </div>
      <div class="pos-cards">
        <div class="pos-card">
          <div class="pos-num ent-num">01</div>
          <h3 class="pos-title">Real-World Experience</h3>
          <p class="pos-body">Years of hands-on work in commercial environments. We've seen the problems, solved the edge cases, and know how to get it done right the first time.</p>
        </div>
        <div class="pos-card">
          <div class="pos-num ent-num">02</div>
          <h3 class="pos-title">No Subcontracting</h3>
          <p class="pos-body">We do the work. Not a general contractor who farms it out. When we show up, the person who picked up the phone is the person doing the job.</p>
        </div>
        <div class="pos-card">
          <div class="pos-num ent-num">03</div>
          <h3 class="pos-title">Cross-Trade Capability</h3>
          <p class="pos-body">Most repairs that fall through the cracks cross trade lines. We work across disciplines — that's exactly where we live.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="div-services" id="services">
    <div class="div-inner">
      <p class="sf-eyebrow ent-eye">What We Do</p>
      <h2 class="div-section-title">Services</h2>
      <div class="services-grid">
        <div class="service-item">
          <div class="service-rule ent-rule"></div>
          <h3 class="service-name">Custom Fabrication</h3>
          <p class="service-desc">Custom-built components for commercial environments. If it doesn't exist off the shelf, we build it to spec — cabinetry, countertops, enclosures, access panels, and structural components.</p>
        </div>
        <div class="service-item">
          <div class="service-rule ent-rule"></div>
          <h3 class="service-name">Compactor Chute Systems</h3>
          <p class="service-desc">Installation, repair, and custom fabrication of compactor chutes and waste management infrastructure for multi-tenant retail and pharmacy properties.</p>
        </div>
        <div class="service-item">
          <div class="service-rule ent-rule"></div>
          <h3 class="service-name">Structural Repairs</h3>
          <p class="service-desc">Commercial structural repair work that crosses trade lines — the jobs that fall outside standard scope and require someone who can problem-solve across disciplines.</p>
        </div>
        <div class="service-item">
          <div class="service-rule ent-rule"></div>
          <h3 class="service-name">Wall Access &amp; Security Gates</h3>
          <p class="service-desc">Custom wall access gates, security enclosures, and controlled-access fabrications built to commercial specifications for retail and pharmacy environments.</p>
        </div>
        <div class="service-item">
          <div class="service-rule ent-rule"></div>
          <h3 class="service-name">Pharmacy &amp; Retail Fit-Outs</h3>
          <p class="service-desc">Specialized interior work for pharmacy and retail chain locations — custom cabinetry, millwork, fixture fabrication, and installation.</p>
        </div>
        <div class="service-item">
          <div class="service-rule ent-rule"></div>
          <h3 class="service-name">Site Maintenance</h3>
          <p class="service-desc">Ongoing maintenance support for commercial properties. Consistent, reliable, and done by people who know your site and how it's built.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHO WE SERVE -->
  <section class="div-clients">
    <div class="div-inner div-inner-center">
      <p class="sf-eyebrow ent-eye">Who We Serve</p>
      <h2 class="div-section-title">Built for Commercial Operations</h2>
      <p class="clients-sub">We work with facilities managers, property maintenance teams, and operations directors at commercial chains who need specialized work done right — without the back-and-forth of vendors who've never seen their kind of problem before.</p>
      <div class="pills">
        <span class="pill ent-pill">National Pharmacy Chains</span>
        <span class="pill ent-pill">Retail Property Groups</span>
        <span class="pill ent-pill">Commercial Landlords</span>
        <span class="pill ent-pill">Facilities Managers</span>
        <span class="pill ent-pill">Multi-Site Operators</span>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="div-cta">
    <div class="div-inner div-inner-center">
      <div class="cta-rule ent-bar"></div>
      <h2 class="cta-title">Have a repair or fabrication project<br />that hasn't been solved yet?</h2>
      <p class="cta-sub">Tell us what you're dealing with. No obligation — just a straight conversation about whether we're the right fit.</p>
      <a href="/contact/enterprise" class="btn-primary ent-btn">Request Expert Service</a>
      <p class="cta-phone">Or call Scott directly: <a href="tel:6028828723" class="ent-link">602-882-8723</a></p>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
.div-hero { position:relative;padding:9rem var(--sf-pad) 7rem;background:var(--sf-black);overflow:hidden; }
.div-hero-bg { position:absolute;inset:0;background:url('/hero-bg.png') center/cover no-repeat;opacity:.1;pointer-events:none; }
.hero-accent-bar { position:absolute;bottom:0;left:0;right:0;height:4px; }
.ent-bar { background:var(--sf-ent); }
.div-hero-inner { position:relative;z-index:1;max-width:900px; }
.ent-eye { color:var(--sf-ent-b); }
.div-hero-title { font-family:var(--sf-font-display);font-weight:900;font-size:clamp(3rem,7vw,6.2rem);text-transform:uppercase;color:var(--sf-text-primary);line-height:1;margin:1rem 0 1.5rem; }
.ent-accent { color:var(--sf-ent); }
.div-hero-sub { font-size:1.15rem;color:var(--sf-text-secondary);max-width:640px;line-height:1.8;margin-bottom:2.5rem; }
.div-hero-cta { display:flex;gap:1rem;flex-wrap:wrap; }
.btn-primary { display:inline-block;font-family:var(--sf-font-display);font-weight:700;font-size:.82rem;letter-spacing:.2em;text-transform:uppercase;padding:.9rem 2rem;text-decoration:none;transition:background .2s; }
.ent-btn { background:var(--sf-ent);color:#fff; }
.ent-btn:hover { background:var(--sf-ent-b); }
.btn-ghost { display:inline-block;font-family:var(--sf-font-display);font-weight:700;font-size:.82rem;letter-spacing:.2em;text-transform:uppercase;padding:.9rem 2rem;text-decoration:none;border:1px solid rgba(255,255,255,.2);color:var(--sf-text-secondary);transition:all .2s; }
.btn-ghost:hover { border-color:var(--sf-ent);color:var(--sf-ent); }
.div-inner { max-width:1200px;margin:0 auto; }
.div-inner-center { text-align:center; }
.div-position { padding:6rem var(--sf-pad);background:var(--sf-surface); }
.div-pos-statement { margin-bottom:3.5rem; }
.div-pos-title { font-family:var(--sf-font-display);font-weight:900;font-size:clamp(1.8rem,3.5vw,2.8rem);text-transform:uppercase;color:var(--sf-text-primary);line-height:1.1;margin-top:.75rem; }
.pos-cards { display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:2px; }
.pos-card { background:var(--sf-black);padding:2.5rem; }
.pos-num { font-family:var(--sf-font-display);font-weight:900;font-size:3.5rem;line-height:1;margin-bottom:1rem; }
.ent-num { color:var(--sf-ent);opacity:.25; }
.pos-title { font-family:var(--sf-font-display);font-weight:700;font-size:1.2rem;letter-spacing:.1em;text-transform:uppercase;color:var(--sf-text-primary);margin-bottom:.75rem; }
.pos-body { font-size:.92rem;color:var(--sf-text-secondary);line-height:1.8; }
.div-services { padding:6rem var(--sf-pad);background:var(--sf-black); }
.div-section-title { font-family:var(--sf-font-display);font-weight:900;font-size:clamp(2.2rem,5vw,3.7rem);text-transform:uppercase;color:var(--sf-text-primary);margin:.75rem 0 3rem; }
.services-grid { display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:2px; }
.service-item { background:var(--sf-surface);padding:2rem 2rem 2.5rem; }
.service-rule { height:3px;width:40px;margin-bottom:1.5rem; }
.ent-rule { background:var(--sf-ent); }
.service-name { font-family:var(--sf-font-display);font-weight:700;font-size:1.05rem;letter-spacing:.1em;text-transform:uppercase;color:var(--sf-text-primary);margin-bottom:.75rem; }
.service-desc { font-size:1rem;color:var(--sf-text-secondary);line-height:1.8; }
.div-clients { padding:6rem var(--sf-pad);background:var(--sf-surface); }
.clients-sub { font-size:1.2rem;color:var(--sf-text-secondary);line-height:1.8;max-width:700px;margin:0 auto 2.5rem; }
.pills { display:flex;flex-wrap:wrap;gap:.75rem;justify-content:center; }
.pill { font-family:var(--sf-font-display);font-weight:600;font-size:.82rem;letter-spacing:.25em;text-transform:uppercase;padding:.5rem 1.25rem;border:1px solid; }
.ent-pill { border-color:var(--sf-ent);color:var(--sf-ent); }
.div-cta { padding:7rem var(--sf-pad);background:var(--sf-black); }
.cta-rule { width:48px;height:4px;margin:0 auto 2.5rem; }
.cta-title { font-family:var(--sf-font-display);font-weight:900;font-size:clamp(2rem,4vw,3.2rem);text-transform:uppercase;color:var(--sf-text-primary);line-height:1.1;margin-bottom:1.25rem; }
.cta-sub { font-size:1.2rem;color:var(--sf-text-secondary);line-height:1.75;margin-bottom:2.5rem; }
.cta-phone { margin-top:1.5rem;font-size:1rem;color:var(--sf-text-muted); }
.ent-link { color:var(--sf-ent-b);text-decoration:none; }
.ent-link:hover { text-decoration:underline; }
</style>
