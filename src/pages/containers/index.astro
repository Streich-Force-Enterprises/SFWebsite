---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---
<BaseLayout
  title="Division 03 — Container Sales & Sourcing — Streich Force"
  description="Simple, direct access to available container inventory with clear pricing and no unnecessary friction.">
  <Nav active="containers" />

  <section class="div-hero">
    <div class="div-hero-bg"></div>
    <div class="div-hero-inner">
      <p class="sf-eyebrow con-eye">Division 03 — Container Sales &amp; Sourcing</p>
      <h1 class="div-hero-title">Simple, Direct Access<br /><span class="con-accent">to What You Need</span></h1>
      <p class="div-hero-sub">Finding the right containers shouldn't be complicated.</p>
      <p class="div-hero-sub">We provide straightforward access to available inventory with clear pricing and no unnecessary friction.</p>
      <div class="div-hero-cta">
        <a href="/contact/containers" class="btn-primary con-btn">Get a Quote</a>
        <a href="#" class="btn-ghost con-ghost">View Containers</a>
      </div>
    </div>
    <div class="hero-accent-bar con-bar"></div>
  </section>

  <section class="content-section">
    <div class="section-inner">
      <h2 class="section-title con-title">What We Offer</h2>
      <div class="boxes-4">
        <div class="box"><span class="box-bullet con-bullet">▸</span><p>Available container inventory</p></div>
        <div class="box"><span class="box-bullet con-bullet">▸</span><p>Direct pricing and quotes</p></div>
        <div class="box"><span class="box-bullet con-bullet">▸</span><p>Assistance sourcing specific needs</p></div>
        <div class="box"><span class="box-bullet con-bullet">▸</span><p>Straightforward communication</p></div>
      </div>
    </div>
  </section>

  <section class="content-section alt">
    <div class="section-inner">
      <h2 class="section-title con-title">Why Work With Us</h2>
      <div class="boxes-4">
        <div class="box"><span class="box-bullet con-bullet">▸</span><p>No runaround or delays</p></div>
        <div class="box"><span class="box-bullet con-bullet">▸</span><p>Clear, direct communication</p></div>
        <div class="box"><span class="box-bullet con-bullet">▸</span><p>Fast response on availability</p></div>
        <div class="box"><span class="box-bullet con-bullet">▸</span><p>Practical, no-nonsense process</p></div>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="section-inner">
      <h2 class="section-title con-title">How It Works</h2>
      <div class="boxes-4 centered">
        <div class="box step-box"><span class="step-num con-step">1</span><p>Tell us what you need</p></div>
        <div class="box step-box"><span class="step-num con-step">2</span><p>Review available inventory or sourcing options</p></div>
        <div class="box step-box"><span class="step-num con-step">3</span><p>Receive clear pricing</p></div>
        <div class="box step-box"><span class="step-num con-step">4</span><p>Secure your order quickly</p></div>
      </div>
    </div>
  </section>

  <section class="content-section alt">
    <div class="section-inner">
      <h2 class="section-title con-title">Who This Is For</h2>
      <div class="boxes-4">
        <div class="box"><span class="box-bullet con-bullet">▸</span><p>Businesses needing container supply</p></div>
        <div class="box"><span class="box-bullet con-bullet">▸</span><p>Buyers looking for fast turnaround</p></div>
        <div class="box"><span class="box-bullet con-bullet">▸</span><p>Anyone tired of unclear pricing and delays</p></div>
        <div class="box"><span class="box-bullet con-bullet">▸</span><p>Single unit or bulk — all welcome</p></div>
      </div>
    </div>
  </section>

  <section class="div-cta">
    <div class="cta-inner">
      <div class="cta-rule con-bar"></div>
      <h2 class="cta-title">Looking for containers? Let's talk.</h2>
      <p class="cta-sub">Tell us what you need — size, condition, quantity, and delivery location.</p>
      <a href="/contact/containers" class="btn-primary con-btn">Get a Quote</a>
      <p class="cta-email"><a href="mailto:containers&#x40;streichforce.com" class="con-link">containers&#x40;streichforce.com</a></p>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
.div-hero{position:relative;padding:9rem var(--sf-pad) 7rem;background:var(--sf-black);overflow:hidden}
.div-hero-bg{position:absolute;inset:0;background:url('/hero-bg.png') center/cover no-repeat;opacity:.08;pointer-events:none}
.hero-accent-bar{position:absolute;bottom:0;left:0;right:0;height:4px}
.con-bar{background:var(--sf-con)}
.div-hero-inner{position:relative;z-index:1;max-width:900px}
.con-eye{color:var(--sf-con-b)}
.div-hero-title{font-family:var(--sf-font-display);font-weight:900;font-size:clamp(2.8rem,7vw,6rem);text-transform:uppercase;color:var(--sf-text-primary);line-height:1;margin:1rem 0 1.5rem}
.con-accent{color:var(--sf-con)}
.div-hero-sub{font-size:1.05rem;color:var(--sf-text-secondary);max-width:640px;line-height:1.8;margin-bottom:1rem}
.div-hero-cta{display:flex;gap:1rem;flex-wrap:wrap;margin-top:2rem}
.btn-primary{display:inline-block;font-family:var(--sf-font-display);font-weight:700;font-size:.78rem;letter-spacing:.2em;text-transform:uppercase;padding:.9rem 2rem;text-decoration:none;transition:background .2s}
.con-btn{background:var(--sf-con);color:#fff}
.con-btn:hover{background:var(--sf-con-b)}
.btn-ghost{display:inline-block;font-family:var(--sf-font-display);font-weight:700;font-size:.78rem;letter-spacing:.2em;text-transform:uppercase;padding:.9rem 2rem;text-decoration:none;border:1px solid rgba(255,255,255,.2);color:var(--sf-text-secondary);transition:all .2s}
.con-ghost:hover{border-color:var(--sf-con);color:var(--sf-con)}
.content-section{padding:5rem var(--sf-pad);background:var(--sf-black)}
.content-section.alt{background:var(--sf-surface)}
.section-inner{max-width:1200px;margin:0 auto}
.section-title{font-family:var(--sf-font-display);font-weight:900;font-size:clamp(1.6rem,3vw,2.4rem);text-transform:uppercase;letter-spacing:.04em;margin-bottom:2.5rem}
.con-title{color:var(--sf-con-b)}
.boxes-4{display:grid;grid-template-columns:repeat(4,1fr);gap:2px}
@media(max-width:900px){.boxes-4{grid-template-columns:repeat(2,1fr)}}
@media(max-width:500px){.boxes-4{grid-template-columns:1fr}}
.box{background:var(--sf-surface);padding:2rem 1.75rem;display:flex;flex-direction:column;align-items:flex-start;gap:1rem}
.content-section.alt .box{background:var(--sf-black)}
.box-bullet{font-size:1.4rem;line-height:1;flex-shrink:0}
.con-bullet{color:var(--sf-con)}
.box p{font-size:1rem;color:var(--sf-text-secondary);line-height:1.7;margin:0}
.boxes-4.centered{justify-items:center}
.step-box{align-items:center;text-align:center}
.step-num{font-family:var(--sf-font-display);font-weight:900;font-size:2.8rem;line-height:1;flex-shrink:0}
.con-step{color:var(--sf-con)}
.div-cta{padding:7rem var(--sf-pad);background:var(--sf-black);text-align:center}
.cta-inner{max-width:680px;margin:0 auto}
.cta-rule{width:48px;height:4px;margin:0 auto 2.5rem}
.cta-title{font-family:var(--sf-font-display);font-weight:900;font-size:clamp(1.8rem,4vw,3rem);text-transform:uppercase;color:var(--sf-text-primary);line-height:1.1;margin-bottom:1.25rem}
.cta-sub{font-size:1rem;color:var(--sf-text-secondary);line-height:1.75;margin-bottom:2rem}
.cta-email{margin-top:1.5rem;font-size:.9rem;color:var(--sf-text-muted)}
.con-link{color:var(--sf-con-b);text-decoration:none}
.con-link:hover{text-decoration:underline}
</style>
