---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---
<BaseLayout
  title="Division 01 — Commercial Service & Repair — Streich Force"
  description="High-level diagnostics and precision repair for commercial environments where others fall short.">
  <Nav active="services" />

  <!-- HERO -->
  <section class="div-hero">
    <div class="div-hero-bg"></div>
    <div class="div-hero-inner">
      <p class="sf-eyebrow ent-eye">Division 01 — Commercial Service &amp; Repair</p>
      <h1 class="div-hero-title">When It Has to<br /><span class="ent-accent">Be Done Right</span></h1>
      <p class="div-hero-sub">Not every job requires a specialist. But when it does, you need someone who knows exactly what they're doing.</p>
      <p class="div-hero-sub">Streich Force provides high-level diagnostics and precision repair for commercial environments where others fall short.</p>
      <div class="div-hero-cta">
        <a href="/contact/enterprise" class="btn-primary ent-btn">Request Expert Service</a>
        <a href="#" class="btn-ghost">View Our Work</a>
      </div>
    </div>
    <div class="hero-accent-bar ent-bar"></div>
  </section>

  <!-- WHAT WE HANDLE -->
  <section class="content-section">
    <div class="section-inner">
      <h2 class="section-title ent-title">What We Handle</h2>
      <div class="boxes-4">
        <div class="box"><span class="box-bullet ent-bullet">▸</span><p>Complex system failures</p></div>
        <div class="box"><span class="box-bullet ent-bullet">▸</span><p>Ongoing issues others couldn't resolve</p></div>
        <div class="box"><span class="box-bullet ent-bullet">▸</span><p>Custom fabrication and problem-solving</p></div>
        <div class="box"><span class="box-bullet ent-bullet">▸</span><p>Commercial site maintenance and repair</p></div>
      </div>
    </div>
  </section>

  <!-- WHY CLIENTS CALL US -->
  <section class="content-section alt">
    <div class="section-inner">
      <h2 class="section-title ent-title">Why Clients Call Us</h2>
      <div class="boxes-4">
        <div class="box"><span class="box-bullet ent-bullet">▸</span><p>40+ years of hands-on experience</p></div>
        <div class="box"><span class="box-bullet ent-bullet">▸</span><p>Trusted by national brands and commercial sites</p></div>
        <div class="box"><span class="box-bullet ent-bullet">▸</span><p>Problems solved correctly the first time</p></div>
        <div class="box"><span class="box-bullet ent-bullet">▸</span><p>No trial-and-error approach</p></div>
      </div>
    </div>
  </section>

  <!-- HOW WE WORK -->
  <section class="content-section">
    <div class="section-inner">
      <h2 class="section-title ent-title">How We Work</h2>
      <div class="boxes-4 centered">
        <div class="box step-box"><div class="step-ghost" style="color:var(--sf-ent)">1</div><p>Assess the real issue (not just the symptoms)</p></div>
        <div class="box step-box"><div class="step-ghost" style="color:var(--sf-ent)">2</div><p>Identify the correct fix</p></div>
        <div class="box step-box"><div class="step-ghost" style="color:var(--sf-ent)">3</div><p>Execute with precision</p></div>
        <div class="box step-box"><div class="step-ghost" style="color:var(--sf-ent)">4</div><p>Ensure it's done right before we leave</p></div>
      </div>
    </div>
  </section>

  <!-- WHO THIS IS FOR -->
  <section class="content-section alt">
    <div class="section-inner">
      <h2 class="section-title ent-title">Who This Is For</h2>
      <div class="boxes-4">
        <div class="box"><span class="box-bullet ent-bullet">▸</span><p>Commercial facilities</p></div>
        <div class="box"><span class="box-bullet ent-bullet">▸</span><p>Retail chains</p></div>
        <div class="box"><span class="box-bullet ent-bullet">▸</span><p>Businesses dealing with recurring or unresolved issues</p></div>
        <div class="box"><span class="box-bullet ent-bullet">▸</span><p>Anyone tired of paying for the same problem twice</p></div>
      </div>
    </div>
  </section>

  <!-- BOTTOM CTA -->
  <section class="div-cta">
    <div class="cta-inner">
      <div class="cta-rule ent-bar"></div>
      <h2 class="cta-title">Get It Fixed Right</h2>
      <p class="cta-sub">Tell us what you're dealing with. No obligation — just a straight conversation about whether we're the right fit.</p>
      <a href="/contact/enterprise" class="btn-primary ent-btn">Request Expert Service</a>
      <p class="cta-email"><a href="mailto:services&#x40;streichforce.com" class="ent-link">services&#x40;streichforce.com</a></p>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
.div-hero{position:relative;padding:9rem var(--sf-pad) 7rem;background:var(--sf-black);overflow:hidden}
.div-hero-bg{position:absolute;inset:0;background:url('/hero-bg.png') center/cover no-repeat;opacity:.1;pointer-events:none}
.hero-accent-bar{position:absolute;bottom:0;left:0;right:0;height:4px}
.ent-bar{background:var(--sf-ent)}
.div-hero-inner{position:relative;z-index:1;max-width:900px}
.ent-eye{color:var(--sf-ent-b)}
.div-hero-title{font-family:var(--sf-font-display);font-weight:900;font-size:clamp(2.8rem,7vw,6rem);text-transform:uppercase;color:var(--sf-text-primary);line-height:1;margin:1rem 0 1.5rem}
.ent-accent{color:var(--sf-ent)}
.div-hero-sub{font-size:1.05rem;color:var(--sf-text-secondary);max-width:640px;line-height:1.8;margin-bottom:1rem}
.div-hero-cta{display:flex;gap:1rem;flex-wrap:wrap;margin-top:2rem}
.btn-primary{display:inline-block;font-family:var(--sf-font-display);font-weight:700;font-size:.78rem;letter-spacing:.2em;text-transform:uppercase;padding:.9rem 2rem;text-decoration:none;transition:background .2s}
.ent-btn{background:var(--sf-ent);color:#fff}
.ent-btn:hover{background:var(--sf-ent-b)}
.btn-ghost{display:inline-block;font-family:var(--sf-font-display);font-weight:700;font-size:.78rem;letter-spacing:.2em;text-transform:uppercase;padding:.9rem 2rem;text-decoration:none;border:1px solid rgba(255,255,255,.2);color:var(--sf-text-secondary);transition:all .2s}
.btn-ghost:hover{border-color:var(--sf-ent);color:var(--sf-ent)}

/* SECTIONS */
.content-section{padding:5rem var(--sf-pad);background:var(--sf-black)}
.content-section.alt{background:var(--sf-surface)}
.section-inner{max-width:1200px;margin:0 auto}
.section-title{font-family:var(--sf-font-display);font-weight:900;font-size:clamp(1.6rem,3vw,2.4rem);text-transform:uppercase;letter-spacing:.04em;margin-bottom:2.5rem}
.ent-title{color:var(--sf-ent-b)}

/* 4-BOX GRID */
.boxes-4{display:grid;grid-template-columns:repeat(4,1fr);gap:2px}
@media(max-width:900px){.boxes-4{grid-template-columns:repeat(2,1fr)}}
@media(max-width:500px){.boxes-4{grid-template-columns:1fr}}
.box{background:var(--sf-surface);padding:2rem 1.75rem;display:flex;flex-direction:row;align-items:flex-start;gap:.85rem}
.content-section.alt .box{background:var(--sf-black)}
.box-bullet{font-size:1.4rem;line-height:1;flex-shrink:0}
.ent-bullet{color:var(--sf-ent);font-size:.95rem;flex-shrink:0;margin-top:.28em;line-height:1}
.box p{font-size:1.1rem;color:var(--sf-text-secondary);line-height:1.65;margin:0}

/* STEP BOXES */
.boxes-4.centered{justify-items:stretch}
.step-box{align-items:center;text-align:center}

/* CTA */
.div-cta{padding:7rem var(--sf-pad);background:var(--sf-black);text-align:center}
.cta-inner{max-width:680px;margin:0 auto}
.cta-rule{width:48px;height:4px;margin:0 auto 2.5rem}
.cta-title{font-family:var(--sf-font-display);font-weight:900;font-size:clamp(1.8rem,4vw,3rem);text-transform:uppercase;color:var(--sf-text-primary);line-height:1.1;margin-bottom:1.25rem}
.cta-sub{font-size:1rem;color:var(--sf-text-secondary);line-height:1.75;margin-bottom:2rem}
.cta-email{margin-top:1.5rem;font-size:.9rem;color:var(--sf-text-muted)}
.ent-link{color:var(--sf-ent-b);text-decoration:none}
.ent-link:hover{text-decoration:underline}

.step-box{position:relative;align-items:center;text-align:center;flex-direction:column;justify-content:center;min-height:170px;overflow:hidden;gap:0;padding:1.5rem}
.step-ghost{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-family:var(--sf-font-display);font-weight:900;font-size:8rem;line-height:1;pointer-events:none;user-select:none;z-index:0;opacity:.13;letter-spacing:-.02em}
.step-box p{position:relative;z-index:1;font-size:1.1rem;color:var(--sf-text-primary);line-height:1.65;margin:0;font-weight:500;padding:0 .5rem}
</style>
