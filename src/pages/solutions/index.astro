---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---
<BaseLayout
  title="Division 02 — Back-Office Support & Systems — Streich Force"
  description="We help you eliminate inefficiencies, clean up your data, and build workflows that actually work.">
  <Nav active="solutions" />

  <section class="div-hero">
    <div class="div-hero-bg"></div>
    <div class="div-hero-inner">
      <p class="sf-eyebrow sol-eye">Division 02 — Back-Office Support &amp; Systems</p>
      <h1 class="div-hero-title">Fix What's Slowing<br /><span class="sol-accent">Your Business Down</span></h1>
      <p class="div-hero-sub">Most businesses don't struggle because of demand. They struggle because of what's happening behind the scenes.<br /><br />We help you eliminate inefficiencies, clean up your data, and build workflows that actually work.</p>
      <div class="div-hero-cta">
        <a href="/contact/solutions" class="btn-primary sol-btn">Fix My Back Office</a>
        <a href="#what-we-handle" class="btn-ghost sol-ghost">See How It Works</a>
      </div>
    </div>
    <div class="hero-accent-bar sol-bar"></div>
  </section>

  <section class="div-content" id="what-we-handle">
    <div class="div-inner">
      <div class="content-grid">

        <div class="content-block">
          <h2 class="block-title sol-title">What We Handle</h2>
          <ul class="block-list sol-list">
            <li>Billing and back-office operations</li>
            <li>Data cleanup and standardization</li>
            <li>Workflow organization and automation</li>
            <li>Ongoing operational support</li>
          </ul>
        </div>

        <div class="content-block">
          <h2 class="block-title sol-title">What Makes This Different</h2>
          <ul class="block-list sol-list">
            <li>Built from real operational experience</li>
            <li>Designed to reduce overhead — not add to it</li>
            <li>Structured to scale with your business</li>
            <li>Connected to smarter systems (including future integrations like Triplemeter)</li>
          </ul>
        </div>

        <div class="content-block">
          <h2 class="block-title sol-title">How It Works</h2>
          <ol class="block-steps">
            <li><span class="step-num sol-num">1</span><span>Review your current processes</span></li>
            <li><span class="step-num sol-num">2</span><span>Identify breakdowns and inefficiencies</span></li>
            <li><span class="step-num sol-num">3</span><span>Clean and standardize your data</span></li>
            <li><span class="step-num sol-num">4</span><span>Implement structured workflows</span></li>
            <li><span class="step-num sol-num">5</span><span>Provide ongoing support as needed</span></li>
          </ol>
        </div>

        <div class="content-block">
          <h2 class="block-title sol-title">Who This Is For</h2>
          <ul class="block-list sol-list">
            <li>Businesses with messy or inconsistent data</li>
            <li>Teams relying on manual processes</li>
            <li>Owners spending too much time on admin work</li>
            <li>Companies ready to operate more efficiently</li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <section class="div-cta">
    <div class="div-inner div-inner-center">
      <div class="cta-rule sol-bar"></div>
      <h2 class="cta-title">Fix Your Back Office</h2>
      <p class="cta-sub">Spreadsheets, wearing too many hats, a mix of both? Tell us what your setup looks like — no obligation, just a straight conversation.</p>
      <div class="cta-actions">
        <a href="/contact/solutions" class="btn-primary sol-btn">Fix My Back Office</a>
        <a href="#" class="btn-ghost sol-ghost">Case Studies</a>
      </div>
      <p class="cta-email"><a href="mailto:solutions&#x40;streichforce.com" class="sol-link">solutions&#x40;streichforce.com</a></p>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
.div-hero { position:relative;padding:9rem var(--sf-pad) 7rem;background:var(--sf-black);overflow:hidden; }
.div-hero-bg { position:absolute;inset:0;background:url('/hero-bg.png') center/cover no-repeat;opacity:.08;pointer-events:none; }
.hero-accent-bar { position:absolute;bottom:0;left:0;right:0;height:4px; }
.sol-bar { background:var(--sf-sol); }
.div-hero-inner { position:relative;z-index:1;max-width:900px; }
.sol-eye { color:var(--sf-sol-b); }
.div-hero-title { font-family:var(--sf-font-display);font-weight:900;font-size:clamp(2.8rem,7vw,6rem);text-transform:uppercase;color:var(--sf-text-primary);line-height:1;margin:1rem 0 1.5rem; }
.sol-accent { color:var(--sf-sol); }
.div-hero-sub { font-size:1.05rem;color:var(--sf-text-secondary);max-width:640px;line-height:1.8;margin-bottom:2.5rem; }
.div-hero-cta { display:flex;gap:1rem;flex-wrap:wrap; }
.btn-primary { display:inline-block;font-family:var(--sf-font-display);font-weight:700;font-size:.75rem;letter-spacing:.2em;text-transform:uppercase;padding:.9rem 2rem;text-decoration:none;transition:background .2s; }
.sol-btn { background:var(--sf-sol);color:#fff; }
.sol-btn:hover { background:var(--sf-sol-b); }
.btn-ghost { display:inline-block;font-family:var(--sf-font-display);font-weight:700;font-size:.75rem;letter-spacing:.2em;text-transform:uppercase;padding:.9rem 2rem;text-decoration:none;border:1px solid rgba(255,255,255,.2);color:var(--sf-text-secondary);transition:all .2s; }
.sol-ghost:hover { border-color:var(--sf-sol);color:var(--sf-sol); }
.div-inner { max-width:1200px;margin:0 auto; }
.div-inner-center { text-align:center; }
.div-content { padding:6rem var(--sf-pad);background:var(--sf-surface); }
.content-grid { display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:2px; }
.content-block { background:var(--sf-black);padding:2.5rem; }
.block-title { font-family:var(--sf-font-display);font-weight:700;font-size:1.05rem;letter-spacing:.1em;text-transform:uppercase;margin-bottom:1.5rem; }
.sol-title { color:var(--sf-sol-b); }
.block-list { list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:.75rem; }
.block-list li { font-size:1rem;color:var(--sf-text-secondary);line-height:1.7;padding-left:1.25rem;position:relative; }
.sol-list li::before { content:'▸';position:absolute;left:0;color:var(--sf-sol);font-size:.8rem;top:.2em; }
.block-steps { list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:1rem; }
.block-steps li { display:flex;align-items:flex-start;gap:.75rem;font-size:1rem;color:var(--sf-text-secondary);line-height:1.6; }
.step-num { font-family:var(--sf-font-display);font-weight:900;font-size:1.2rem;flex-shrink:0;line-height:1.4; }
.sol-num { color:var(--sf-sol); }
.div-cta { padding:7rem var(--sf-pad);background:var(--sf-black); }
.cta-rule { width:48px;height:4px;margin:0 auto 2.5rem; }
.cta-title { font-family:var(--sf-font-display);font-weight:900;font-size:clamp(1.8rem,4vw,3rem);text-transform:uppercase;color:var(--sf-text-primary);line-height:1.1;margin-bottom:1.25rem; }
.cta-sub { font-size:1rem;color:var(--sf-text-secondary);line-height:1.75;margin-bottom:2rem;max-width:600px;margin-left:auto;margin-right:auto; }
.cta-actions { display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-bottom:1.5rem; }
.cta-email { font-size:.9rem;color:var(--sf-text-muted); }
.sol-link { color:var(--sf-sol-b);text-decoration:none; }
.sol-link:hover { text-decoration:underline; }
</style>
