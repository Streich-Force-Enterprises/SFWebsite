---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="Solutions — Back-Office Operations"
  description="An extension of your back office. Dedicated operational support for container wholesalers and small businesses — inventory, orders, invoicing, and coordination."
>
  <Nav active="solutions" />

  <!-- HERO -->
  <section class="div-hero">
    <div class="div-hero-bg"></div>
    <div class="div-hero-inner">
      <p class="sf-eyebrow sol-eye">Division 02 &mdash; Back-Office Operations</p>
      <h1 class="div-hero-title">An Extension of<br /><span class="sol-accent">Your Back Office</span></h1>
      <p class="div-hero-sub">We become your dedicated operational team — managing inventory, orders, invoicing, gate activity, and daily coordination so you can focus on growing the business.</p>
      <div class="div-hero-cta">
        <a href="/contact/solutions" class="btn-primary sol-btn">Fix My Back Office</a>
        <a href="#how-it-works" class="btn-ghost sol-ghost">How It Works</a>
      </div>
    </div>
    <div class="hero-accent-bar sol-bar"></div>
  </section>

  <!-- PROBLEM -->
  <section class="div-problem">
    <div class="div-inner">
      <p class="sf-eyebrow sol-eye">The Problem</p>
      <h2 class="div-section-title">Running without a dedicated ops team<br />costs more than you think.</h2>
      <div class="problem-grid">
        <div class="problem-item">
          <span class="problem-label">Orders tracked in spreadsheets</span>
          <p class="problem-desc">Manual tracking creates errors, delays, and gaps in visibility that turn into real operational costs.</p>
        </div>
        <div class="problem-item">
          <span class="problem-label">Gate activity logged by hand</span>
          <p class="problem-desc">Without real-time gate tracking, discrepancies pile up and disputes become difficult to resolve.</p>
        </div>
        <div class="problem-item">
          <span class="problem-label">Invoices delayed or missed</span>
          <p class="problem-desc">When nobody has time to process invoicing, cash flow suffers and clients get frustrated.</p>
        </div>
        <div class="problem-item">
          <span class="problem-label">Storage fees climbing</span>
          <p class="problem-desc">Without real-time inventory visibility, containers sit too long and storage fees eat into margin silently.</p>
        </div>
      </div>
      <p class="problem-closer">That's not a staffing problem. That's a systems problem. And it's exactly what we fix.</p>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="div-how" id="how-it-works">
    <div class="div-inner">
      <p class="sf-eyebrow sol-eye">How It Works</p>
      <h2 class="div-section-title">We Plug In. You Run the Business.</h2>
      <div class="how-steps">
        <div class="how-step">
          <div class="step-num sol-num">01</div>
          <h3 class="step-title">Onboarding</h3>
          <p class="step-body">We get inside your operation — how you buy, sell, move, and invoice containers. We set up Triplemeter as your system of record and establish your workflows.</p>
        </div>
        <div class="how-arrow sol-arrow">&#8594;</div>
        <div class="how-step">
          <div class="step-num sol-num">02</div>
          <h3 class="step-title">We Handle the Day-to-Day</h3>
          <p class="step-body">Inventory management, gate activity tracking, order and sales processing, invoicing, AR coordination, and exceptions management — all handled by us.</p>
        </div>
        <div class="how-arrow sol-arrow">&#8594;</div>
        <div class="how-step">
          <div class="step-num sol-num">03</div>
          <h3 class="step-title">You Get Visibility</h3>
          <p class="step-body">Your data builds in real time inside Triplemeter. Monthly reporting, exception flags, and a clean operational picture — without you having to manage the platform.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="div-services">
    <div class="div-inner">
      <p class="sf-eyebrow sol-eye">What We Manage</p>
      <h2 class="div-section-title">Services</h2>
      <div class="services-grid">
        <div class="service-item">
          <div class="service-rule sol-rule"></div>
          <h3 class="service-name">Inventory Management</h3>
          <p class="service-desc">Real-time container inventory tracking powered by Triplemeter. Know exactly what you have, where it is, and what its status is at any moment.</p>
        </div>
        <div class="service-item">
          <div class="service-rule sol-rule"></div>
          <h3 class="service-name">Gate Activity Tracking</h3>
          <p class="service-desc">Every gate-in and gate-out logged and reconciled. Discrepancies caught and flagged before they become disputes.</p>
        </div>
        <div class="service-item">
          <div class="service-rule sol-rule"></div>
          <h3 class="service-name">Order &amp; Sales Processing</h3>
          <p class="service-desc">Purchase orders, sales orders, and release management handled end-to-end. Nothing falls through the cracks.</p>
        </div>
        <div class="service-item">
          <div class="service-rule sol-rule"></div>
          <h3 class="service-name">Invoicing &amp; AR Coordination</h3>
          <p class="service-desc">Invoices issued on time, payments tracked, and outstanding balances flagged. Your cash flow stays visible and managed.</p>
        </div>
        <div class="service-item">
          <div class="service-rule sol-rule"></div>
          <h3 class="service-name">Exceptions Management</h3>
          <p class="service-desc">Discrepancies, mismatches, and operational flags identified, tracked, and resolved — with full documentation.</p>
        </div>
        <div class="service-item">
          <div class="service-rule sol-rule"></div>
          <h3 class="service-name">Monthly Reporting</h3>
          <p class="service-desc">Clean monthly operational reports covering inventory, gate activity, invoicing, and exceptions. The full picture in one place.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- TRIPLEMETER -->
  <section class="div-tm">
    <div class="div-inner div-inner-split">
      <div class="tm-text">
        <p class="sf-eyebrow sol-eye">Powered By</p>
        <h2 class="tm-title">Triplemeter</h2>
        <p class="tm-body">Streich Force Solutions runs on Triplemeter — a real-time operations and trade platform built specifically for container logistics. Every client's data is recorded, maintained, and fully intact inside their own Triplemeter organization.</p>
        <p class="tm-body">When your business grows and you're ready to take direct control, everything is already there. Your history, your connections, your data. You don't rebuild — you just take over.</p>
        <span class="tm-badge">Triplemeter Managed Services Partner</span>
      </div>
      <div class="tm-aside">
        <div class="tm-stat">
          <span class="tm-stat-num sol-accent">Real-Time</span>
          <span class="tm-stat-label">Inventory Visibility</span>
        </div>
        <div class="tm-stat">
          <span class="tm-stat-num sol-accent">Zero</span>
          <span class="tm-stat-label">Migration Cost When You Graduate</span>
        </div>
        <div class="tm-stat">
          <span class="tm-stat-num sol-accent">Full</span>
          <span class="tm-stat-label">Operational History Intact</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="div-cta">
    <div class="div-inner div-inner-center">
      <div class="cta-rule sol-bar"></div>
      <h2 class="cta-title">What does your back-office<br />setup look like right now?</h2>
      <p class="cta-sub">Spreadsheets, a part-time person, a mix of both? Hit reply and tell us where things stand. No pitch — just a straight conversation about whether we can help.</p>
      <a href="/contact/solutions" class="btn-primary sol-btn">Fix My Back Office</a>
      <p class="cta-phone">Or call Sonja directly: <a href="tel:6024050031" class="sol-link">602-405-0031</a></p>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
.div-hero { position:relative;padding:9rem var(--sf-pad) 7rem;background:var(--sf-black);overflow:hidden; }
.div-hero-bg { position:absolute;inset:0;background:url('/hero-bg.png') center/cover no-repeat;opacity:.08;pointer-events:none; }
.hero-accent-bar { position:absolute;bottom:0;left:0;right:0;height:4px; }
.sol-bar { background:var(--sf-sol); }
.div-hero-inner { position:relative;z-index:1;max-width:900px; }
.sol-eye { color:var(--sf-sol-b); }
.div-hero-title { font-family:var(--sf-font-display);font-weight:900;font-size:clamp(3rem,7vw,6.2rem);text-transform:uppercase;color:var(--sf-text-primary);line-height:1;margin:1rem 0 1.5rem; }
.sol-accent { color:var(--sf-sol); }
.div-hero-sub { font-size:1.15rem;color:var(--sf-text-secondary);max-width:640px;line-height:1.8;margin-bottom:2.5rem; }
.div-hero-cta { display:flex;gap:1rem;flex-wrap:wrap; }
.btn-primary { display:inline-block;font-family:var(--sf-font-display);font-weight:700;font-size:.82rem;letter-spacing:.2em;text-transform:uppercase;padding:.9rem 2rem;text-decoration:none;transition:background .2s; }
.sol-btn { background:var(--sf-sol);color:#fff; }
.sol-btn:hover { background:var(--sf-sol-b); }
.btn-ghost { display:inline-block;font-family:var(--sf-font-display);font-weight:700;font-size:.82rem;letter-spacing:.2em;text-transform:uppercase;padding:.9rem 2rem;text-decoration:none;border:1px solid rgba(255,255,255,.2);color:var(--sf-text-secondary);transition:all .2s; }
.sol-ghost:hover { border-color:var(--sf-sol);color:var(--sf-sol); }
.div-inner { max-width:1200px;margin:0 auto; }
.div-inner-center { text-align:center; }
.div-inner-split { display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center; }
@media(max-width:768px) { .div-inner-split { grid-template-columns:1fr; } }
.div-section-title { font-family:var(--sf-font-display);font-weight:900;font-size:clamp(2.2rem,5vw,3.7rem);text-transform:uppercase;color:var(--sf-text-primary);margin:.75rem 0 3rem; }
.div-problem { padding:6rem var(--sf-pad);background:var(--sf-surface); }
.problem-grid { display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:2px;margin-bottom:3rem; }
.problem-item { background:var(--sf-black);padding:2rem; }
.problem-label { display:block;font-family:var(--sf-font-display);font-weight:700;font-size:.85rem;letter-spacing:.1em;text-transform:uppercase;color:var(--sf-text-primary);margin-bottom:.75rem; }
.problem-desc { font-size:1rem;color:var(--sf-text-secondary);line-height:1.75; }
.problem-closer { font-family:var(--sf-font-display);font-weight:700;font-size:1.2rem;letter-spacing:.05em;color:var(--sf-sol-b);text-transform:uppercase; }
.div-how { padding:6rem var(--sf-pad);background:var(--sf-black); }
.how-steps { display:flex;align-items:flex-start;gap:1.5rem;flex-wrap:wrap; }
.how-step { flex:1;min-width:220px;background:var(--sf-surface);padding:2.5rem; }
.how-arrow { font-size:2rem;color:var(--sf-sol);opacity:.4;padding-top:3rem;flex-shrink:0; }
.step-num { font-family:var(--sf-font-display);font-weight:900;font-size:3.5rem;line-height:1;margin-bottom:1rem; }
.sol-num { color:var(--sf-sol);opacity:.3; }
.step-title { font-family:var(--sf-font-display);font-weight:700;font-size:1.05rem;letter-spacing:.1em;text-transform:uppercase;color:var(--sf-text-primary);margin-bottom:.75rem; }
.step-body { font-size:1rem;color:var(--sf-text-secondary);line-height:1.8; }
.div-services { padding:6rem var(--sf-pad);background:var(--sf-surface); }
.services-grid { display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:2px; }
.service-item { background:var(--sf-black);padding:2rem 2rem 2.5rem; }
.service-rule { height:3px;width:40px;margin-bottom:1.5rem; }
.sol-rule { background:var(--sf-sol); }
.service-name { font-family:var(--sf-font-display);font-weight:700;font-size:1.05rem;letter-spacing:.1em;text-transform:uppercase;color:var(--sf-text-primary);margin-bottom:.75rem; }
.service-desc { font-size:1rem;color:var(--sf-text-secondary);line-height:1.8; }
.div-tm { padding:6rem var(--sf-pad);background:var(--sf-black); }
.tm-title { font-family:var(--sf-font-display);font-weight:900;font-size:clamp(2rem,5vw,4rem);text-transform:uppercase;color:var(--sf-text-primary);margin:.75rem 0 1.5rem; }
.tm-body { font-size:.95rem;color:var(--sf-text-secondary);line-height:1.8;margin-bottom:1.25rem; }
.tm-badge { display:inline-block;font-family:var(--sf-font-display);font-weight:600;font-size:.82rem;letter-spacing:.25em;text-transform:uppercase;padding:.5rem 1.25rem;border:1px solid var(--sf-sol);color:var(--sf-sol);margin-top:1rem; }
.tm-aside { display:flex;flex-direction:column;gap:2.5rem; }
.tm-stat { display:flex;flex-direction:column;gap:.25rem;padding-left:1.5rem;border-left:3px solid var(--sf-sol); }
.tm-stat-num { font-family:var(--sf-font-display);font-weight:900;font-size:2rem;color:var(--sf-sol); }
.tm-stat-label { font-family:var(--sf-font-display);font-weight:600;font-size:.9rem;letter-spacing:.2em;text-transform:uppercase;color:var(--sf-text-secondary); }
.div-cta { padding:7rem var(--sf-pad);background:var(--sf-surface); }
.cta-rule { width:48px;height:4px;margin:0 auto 2.5rem; }
.cta-title { font-family:var(--sf-font-display);font-weight:900;font-size:clamp(2rem,4vw,3.2rem);text-transform:uppercase;color:var(--sf-text-primary);line-height:1.1;margin-bottom:1.25rem; }
.cta-sub { font-size:1.2rem;color:var(--sf-text-secondary);line-height:1.75;margin-bottom:2.5rem;max-width:600px;margin-left:auto;margin-right:auto; }
.cta-phone { margin-top:1.5rem;font-size:1rem;color:var(--sf-text-muted); }
.sol-link { color:var(--sf-sol-b);text-decoration:none; }
.sol-link:hover { text-decoration:underline; }
</style>
