---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---
<BaseLayout
  title="Division 02 — Back-Office Support & Systems — Streich Force"
  description="We help you eliminate inefficiencies, clean up your data, and build workflows that actually work.">
  <Nav active="solutions" />

  <section class="div-hero">
    <div class="div-hero-bg"></div>
    <div class="div-hero-inner">
      <p class="sf-eyebrow sol-eye">Division 02 — Back-Office Support &amp; Systems</p>
      <h1 class="div-hero-title">Fix What's Slowing<br /><span class="sol-accent">Your Business Down</span></h1>
      <p class="div-hero-sub">Most businesses don't struggle because of demand. They struggle because of what's happening behind the scenes.</p>
      <p class="div-hero-sub">We help you eliminate inefficiencies, clean up your data, and build workflows that actually work.</p>
      <div class="div-hero-cta">
        <a href="/contact/solutions" class="btn-primary sol-btn">Fix My Back Office</a>
        <a href="#" class="btn-ghost sol-ghost">Case Studies</a>
      </div>
    </div>
    <div class="hero-accent-bar sol-bar"></div>
  </section>

  <section class="content-section">
    <div class="section-inner">
      <h2 class="section-title sol-title">What We Handle</h2>
      <div class="boxes-4">
        <div class="box"><span class="box-bullet sol-bullet">▸</span><p>Billing and back-office operations</p></div>
        <div class="box"><span class="box-bullet sol-bullet">▸</span><p>Data cleanup and standardization</p></div>
        <div class="box"><span class="box-bullet sol-bullet">▸</span><p>Workflow organization and automation</p></div>
        <div class="box"><span class="box-bullet sol-bullet">▸</span><p>Ongoing operational support</p></div>
      </div>
    </div>
  </section>

  <section class="content-section alt">
    <div class="section-inner">
      <h2 class="section-title sol-title">What Makes This Different</h2>
      <div class="boxes-4">
        <div class="box"><span class="box-bullet sol-bullet">▸</span><p>Built from real operational experience</p></div>
        <div class="box"><span class="box-bullet sol-bullet">▸</span><p>Designed to reduce overhead — not add to it</p></div>
        <div class="box"><span class="box-bullet sol-bullet">▸</span><p>Structured to scale with your business</p></div>
        <div class="box"><span class="box-bullet sol-bullet">▸</span><p>Connected to smarter systems (including future integrations like Triplemeter)</p></div>
      </div>
    </div>
  </section>

  <section class="content-section">
    <div class="section-inner">
      <h2 class="section-title sol-title">How It Works</h2>
      <div class="boxes-4 centered">
        <div class="box step-box"><span class="step-num sol-step">1</span><p>Review your current processes</p></div>
        <div class="box step-box"><span class="step-num sol-step">2</span><p>Identify breakdowns and inefficiencies</p></div>
        <div class="box step-box"><span class="step-num sol-step">3</span><p>Clean and standardize your data</p></div>
        <div class="box step-box"><span class="step-num sol-step">4</span><p>Implement structured workflows and provide ongoing support</p></div>
      </div>
    </div>
  </section>

  <section class="content-section alt">
    <div class="section-inner">
      <h2 class="section-title sol-title">Who This Is For</h2>
      <div class="boxes-4">
        <div class="box"><span class="box-bullet sol-bullet">▸</span><p>Businesses with messy or inconsistent data</p></div>
        <div class="box"><span class="box-bullet sol-bullet">▸</span><p>Teams relying on manual processes</p></div>
        <div class="box"><span class="box-bullet sol-bullet">▸</span><p>Owners spending too much time on admin work</p></div>
        <div class="box"><span class="box-bullet sol-bullet">▸</span><p>Companies ready to operate more efficiently</p></div>
      </div>
    </div>
  </section>

  <section class="div-cta">
    <div class="cta-inner">
      <div class="cta-rule sol-bar"></div>
      <h2 class="cta-title">Fix Your Back Office</h2>
      <p class="cta-sub">Spreadsheets, wearing too many hats, a mix of both? Tell us what your setup looks like — no obligation, just a straight conversation.</p>
      <a href="/contact/solutions" class="btn-primary sol-btn">Fix My Back Office</a>
      <p class="cta-email"><a href="mailto:solutions&#x40;streichforce.com" class="sol-link">solutions&#x40;streichforce.com</a></p>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
.div-hero{position:relative;padding:9rem var(--sf-pad) 7rem;background:var(--sf-black);overflow:hidden}
.div-hero-bg{position:absolute;inset:0;background:url('/hero-bg.png') center/cover no-repeat;opacity:.08;pointer-events:none}
.hero-accent-bar{position:absolute;bottom:0;left:0;right:0;height:4px}
.sol-bar{background:var(--sf-sol)}
.div-hero-inner{position:relative;z-index:1;max-width:900px}
.sol-eye{color:var(--sf-sol-b)}
.div-hero-title{font-family:var(--sf-font-display);font-weight:900;font-size:clamp(2.8rem,7vw,6rem);text-transform:uppercase;color:var(--sf-text-primary);line-height:1;margin:1rem 0 1.5rem}
.sol-accent{color:var(--sf-sol)}
.div-hero-sub{font-size:1.05rem;color:var(--sf-text-secondary);max-width:640px;line-height:1.8;margin-bottom:1rem}
.div-hero-cta{display:flex;gap:1rem;flex-wrap:wrap;margin-top:2rem}
.btn-primary{display:inline-block;font-family:var(--sf-font-display);font-weight:700;font-size:.78rem;letter-spacing:.2em;text-transform:uppercase;padding:.9rem 2rem;text-decoration:none;transition:background .2s}
.sol-btn{background:var(--sf-sol);color:#fff}
.sol-btn:hover{background:var(--sf-sol-b)}
.btn-ghost{display:inline-block;font-family:var(--sf-font-display);font-weight:700;font-size:.78rem;letter-spacing:.2em;text-transform:uppercase;padding:.9rem 2rem;text-decoration:none;border:1px solid rgba(255,255,255,.2);color:var(--sf-text-secondary);transition:all .2s}
.sol-ghost:hover{border-color:var(--sf-sol);color:var(--sf-sol)}
.content-section{padding:5rem var(--sf-pad);background:var(--sf-black)}
.content-section.alt{background:var(--sf-surface)}
.section-inner{max-width:1200px;margin:0 auto}
.section-title{font-family:var(--sf-font-display);font-weight:900;font-size:clamp(1.6rem,3vw,2.4rem);text-transform:uppercase;letter-spacing:.04em;margin-bottom:2.5rem}
.sol-title{color:var(--sf-sol-b)}
.boxes-4{display:grid;grid-template-columns:repeat(4,1fr);gap:2px}
@media(max-width:900px){.boxes-4{grid-template-columns:repeat(2,1fr)}}
@media(max-width:500px){.boxes-4{grid-template-columns:1fr}}
.box{background:var(--sf-surface);padding:2rem 1.75rem;display:flex;flex-direction:column;align-items:flex-start;gap:1rem}
.content-section.alt .box{background:var(--sf-black)}
.box-bullet{font-size:1.4rem;line-height:1;flex-shrink:0}
.sol-bullet{color:var(--sf-sol)}
.box p{font-size:1rem;color:var(--sf-text-secondary);line-height:1.7;margin:0}
.boxes-4.centered{justify-items:center}
.step-box{align-items:center;text-align:center}
.step-num{font-family:var(--sf-font-display);font-weight:900;font-size:2.8rem;line-height:1;flex-shrink:0}
.sol-step{color:var(--sf-sol)}
.div-cta{padding:7rem var(--sf-pad);background:var(--sf-black);text-align:center}
.cta-inner{max-width:680px;margin:0 auto}
.cta-rule{width:48px;height:4px;margin:0 auto 2.5rem}
.cta-title{font-family:var(--sf-font-display);font-weight:900;font-size:clamp(1.8rem,4vw,3rem);text-transform:uppercase;color:var(--sf-text-primary);line-height:1.1;margin-bottom:1.25rem}
.cta-sub{font-size:1rem;color:var(--sf-text-secondary);line-height:1.75;margin-bottom:2rem}
.cta-email{margin-top:1.5rem;font-size:.9rem;color:var(--sf-text-muted)}
.sol-link{color:var(--sf-sol-b);text-decoration:none}
.sol-link:hover{text-decoration:underline}
</style>
