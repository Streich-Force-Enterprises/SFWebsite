---
// src/components/Nav.astro
export interface Props { active?: string; }
const { active = '' } = Astro.props;
---

<nav>
  <a href="/" class="nav-logo">
    <img src="/logo-dark.png" alt="Streich Force Enterprises" class="nav-logo-img" />
  </a>
  <ul class="nav-links">
    <li><a href="/enterprise" class:list={['nent', { active: active === 'enterprise' }]}>Enterprise</a></li>
    <li><a href="/solutions"  class:list={['nsol', { active: active === 'solutions'  }]}>Solutions</a></li>
    <li><a href="/containers" class:list={['ncon', { active: active === 'containers' }]}>Containers</a></li>
    <li><a href="/#contact" class="ncta">Contact</a></li>
    <li><a href="/login"    class="nlogin">Login</a></li>
  </ul>
  <button class="nav-mobile-btn" id="mobileToggle" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<div class="mobile-menu" id="mobileMenu">
  <a href="/enterprise">Enterprise</a>
  <a href="/solutions">Solutions</a>
  <a href="/containers">Containers</a>
  <a href="/#contact">Contact</a>
  <a href="/login">Login</a>
</div>

<style>
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 200;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.85rem var(--sf-pad);
    background: rgba(17,17,17,0.97);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--sf-border);
  }
  .nav-logo { display: flex; align-items: center; }
  .nav-logo-img {
    height: 52px;
    width: auto;
    display: block;
  }
  .nav-links { display: flex; gap: 1.25rem; list-style: none; align-items: center; }
  .nav-links a {
    font-family: var(--sf-font-display); font-weight: 600; font-size: 0.82rem;
    letter-spacing: 0.16em; text-transform: uppercase; color: var(--sf-text-secondary);
    transition: color 0.2s; padding-bottom: 2px; border-bottom: 1px solid transparent;
  }
  .nav-links a:hover, .nav-links a.active { color: var(--sf-text-primary); }
  .nav-links .nent:hover, .nav-links .nent.active { color: var(--sf-ent-b); border-color: var(--sf-ent); }
  .nav-links .nsol:hover, .nav-links .nsol.active { color: var(--sf-sol-b); border-color: var(--sf-sol); }
  .nav-links .ncon:hover, .nav-links .ncon.active { color: var(--sf-con-b); border-color: var(--sf-con); }
  .nav-links .ncta {
    padding: 0.45rem 1.1rem; border: 1px solid var(--sf-rust);
    color: var(--sf-rust) !important; border-bottom: 1px solid var(--sf-rust) !important;
  }
  .nav-links .ncta:hover { background: var(--sf-rust); color: #fff !important; }
  .nav-links .nlogin {
    padding: 0.45rem 1.1rem; border: 1px solid var(--sf-border-md);
    color: var(--sf-text-secondary) !important;
  }
  .nav-links .nlogin:hover { background: var(--sf-surface); color: var(--sf-text-primary) !important; }

  .nav-mobile-btn {
    display: none; background: none; border: none; cursor: pointer;
    padding: 4px; flex-direction: column; gap: 5px;
  }
  .nav-mobile-btn span { display: block; width: 22px; height: 2px; background: var(--sf-text-secondary); }

  .mobile-menu {
    display: none; position: fixed; inset: 0; background: var(--sf-black);
    z-index: 190; padding: 6rem var(--sf-pad) 3rem; flex-direction: column; gap: 0;
  }
  .mobile-menu.open { display: flex; }
  .mobile-menu a {
    font-family: var(--sf-font-display); font-weight: 900; font-size: 2.2rem;
    text-transform: uppercase; color: var(--sf-text-primary); letter-spacing: 0.04em;
    padding: 1rem 0; border-bottom: 1px solid var(--sf-border);
  }
  .mobile-menu a:first-child { border-top: 1px solid var(--sf-border); }

  @media (max-width: 640px) {
    .nav-links { display: none; }
    .nav-mobile-btn { display: flex; }
    .nav-logo-img { height: 42px; }
  }
</style>

<script>
  const toggle = document.getElementById('mobileToggle');
  const menu   = document.getElementById('mobileMenu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('open'));
  menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => menu?.classList.remove('open')));
</script>
