---
// src/components/Footer.astro
const year = new Date().getFullYear();
---

<footer>
  <div class="footer-top">
    <div class="footer-logo">
      <span class="footer-logo-top">STREICH <span class="f">FORCE</span></span>
      <div class="footer-logo-rule"></div>
      <span class="footer-logo-sub">Enterprises &mdash; streichforce.com</span>
    </div>
    <div class="footer-nav">
      <div class="fcol">
        <p class="fcol-title">Divisions</p>
        <ul>
          <li><a href="/enterprise">Streich Force Enterprise</a></li>
          <li><a href="/solutions">Streich Force Solutions</a></li>
          <li><a href="/containers">Streich Force Containers</a></li>
        </ul>
      </div>
      <div class="fcol">
        <p class="fcol-title">Contact</p>
        <ul>
          <li><a href="mailto:info@streichforce.com">info@streichforce.com</a></li>
          <li><a href="mailto:enterprise@streichforce.com">enterprise@streichforce.com</a></li>
          <li><a href="mailto:solutions@streichforce.com">solutions@streichforce.com</a></li>
          <li><a href="mailto:containers@streichforce.com">containers@streichforce.com</a></li>
        </ul>
      </div>
    </div>
  </div>
  <div class="footer-bot">
    <p>&copy; {year} Streich Force Enterprises &mdash; streichforce.com</p>
    <p>All rights reserved.</p>
  </div>
</footer>

<style>
  footer { padding: 3rem var(--sf-pad) 2rem; border-top: 1px solid var(--sf-border); }
  .footer-top {
    display: flex; justify-content: space-between; align-items: flex-start;
    gap: 3rem; margin-bottom: 2.5rem; flex-wrap: wrap;
  }
  .footer-logo { display: flex; flex-direction: column; line-height: 1; gap: 0; }
  .footer-logo-top {
    font-family: var(--sf-font-display); font-weight: 900; font-size: 1rem;
    letter-spacing: 0.07em; text-transform: uppercase; color: var(--sf-text-primary);
  }
  .footer-logo-top .f { color: var(--sf-rust); }
  .footer-logo-rule { height: 1.5px; background: var(--sf-rust); margin: 2px 0; }
  .footer-logo-sub {
    font-family: var(--sf-font-display); font-weight: 600; font-size: 0.42rem;
    letter-spacing: 0.28em; text-transform: uppercase; color: var(--sf-text-muted);
  }
  .footer-nav { display: flex; gap: 4rem; flex-wrap: wrap; }
  .fcol-title {
    font-family: var(--sf-font-display); font-weight: 700; font-size: 0.62rem;
    letter-spacing: 0.3em; text-transform: uppercase; color: var(--sf-rust); margin-bottom: 0.9rem;
  }
  .fcol ul { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
  .fcol a { font-size: 0.875rem; font-weight: 300; color: var(--sf-text-secondary); transition: color 0.2s; }
  .fcol a:hover { color: var(--sf-text-primary); }
  .footer-bot {
    border-top: 1px solid var(--sf-border); padding-top: 1.25rem;
    display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.75rem;
  }
  .footer-bot p { font-size: 0.72rem; color: var(--sf-text-muted); }
  @media (max-width: 640px) { .footer-nav { gap: 2rem; } }
</style>
