---
// src/components/Nav.astro
export interface Props {
  active?: string;
}
const { active = '' } = Astro.props;
---

<nav>
  <a href="/" class="nav-logo">Streich<span>Force</span></a>
  <ul class="nav-links">
    <li><a href="/solutions" class:list={[{ 'nav-active': active === 'solutions' }]}>Solutions</a></li>
    <li><a href="/containers" class:list={[{ 'nav-active': active === 'containers' }]}>Containers</a></li>
    <li><a href="/enterprise" class:list={[{ 'nav-active': active === 'enterprise' }]}>Enterprise</a></li>
    <li><a href="/#contact" class="nav-cta">Contact</a></li>
  </ul>
  <button class="nav-mobile-toggle" aria-label="Toggle menu" id="mobileToggle">
    <span></span><span></span><span></span>
  </button>
</nav>

<div class="mobile-menu" id="mobileMenu">
  <ul>
    <li><a href="/solutions">Solutions</a></li>
    <li><a href="/containers">Containers</a></li>
    <li><a href="/enterprise">Enterprise</a></li>
    <li><a href="/#contact">Contact</a></li>
  </ul>
</div>

<style>
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.2rem var(--page-pad);
    background: linear-gradient(to bottom, rgba(10,10,10,0.98), transparent);
    backdrop-filter: blur(2px);
  }

  .nav-logo {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.3rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--white);
  }

  .nav-logo span { color: var(--rust); }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    list-style: none;
    align-items: center;
  }

  .nav-links a {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--mist);
    transition: color 0.2s;
  }

  .nav-links a:hover,
  .nav-links a.nav-active { color: var(--white); }

  .nav-links .nav-cta {
    color: var(--rust);
    border: 1px solid rgba(192, 57, 43, 0.4);
    padding: 0.4rem 1rem;
    transition: background 0.2s, color 0.2s;
  }

  .nav-links .nav-cta:hover {
    background: var(--rust);
    color: var(--white);
  }

  .nav-mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav-mobile-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--bone);
    transition: transform 0.3s;
  }

  .mobile-menu {
    display: none;
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: var(--black);
    z-index: 99;
    padding: 6rem var(--page-pad) 3rem;
  }

  .mobile-menu.open { display: block; }

  .mobile-menu ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .mobile-menu a {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 2.5rem;
    text-transform: uppercase;
    color: var(--white);
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .nav-mobile-toggle { display: flex; }
  }
</style>

<script>
  const toggle = document.getElementById('mobileToggle');
  const menu = document.getElementById('mobileMenu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('open'));
</script>
